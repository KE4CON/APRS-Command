<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.ManagedModemView"
             x:DataType="vm:ManagedModemViewModel">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="14" Margin="0,4">

      <!-- Header -->
      <StackPanel Spacing="2">
        <TextBlock Text="Managed Local Modem" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Foreground="{DynamicResource TextSubtleBrush}" FontSize="12" TextWrapping="Wrap"
                   Text="APRS Command will launch and manage a local Direwolf process using your audio interface. Use this for DigiRig, SignaLink, or any USB audio interface connected to your radio." />
      </StackPanel>

      <!-- Direwolf status -->
      <Border Grid.Row="1" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
              CornerRadius="6" Padding="14" Background="{DynamicResource CardBgBrush}">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding DirewolfFoundText}" FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <StackPanel Spacing="2">
            <TextBlock Text="Direwolf path (leave blank to use system PATH)"
                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                       ToolTip.Tip="If Direwolf is installed via Homebrew or apt, leave this blank. If it is installed to a custom location, enter the full path to the direwolf executable." />
            <TextBox Text="{Binding DirewolfPath}"
                     Watermark="e.g. /usr/local/bin/direwolf or C:\Direwolf\direwolf.exe" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Enable + audio -->
      <Border Grid.Row="2" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
              CornerRadius="6" Padding="14" Background="{DynamicResource CardBgBrush}">
        <StackPanel Spacing="10">
          <CheckBox Content="Enable managed local modem" IsChecked="{Binding Enabled}"
                    FontWeight="SemiBold" />

          <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="10">
            <StackPanel Spacing="2">
              <TextBlock Text="Audio input (from radio)" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}"
                         ToolTip.Tip="The audio device receiving audio from your radio's speaker or headphone jack." />
              <ComboBox ItemsSource="{Binding AudioInputDevices}"
                        SelectedItem="{Binding AudioInputDevice}"
                        IsEditable="True" Text="{Binding AudioInputDevice}"
                        PlaceholderText="Select input device"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Audio output (to radio)" FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}"
                         ToolTip.Tip="The audio device sending audio to your radio's microphone input." />
              <ComboBox ItemsSource="{Binding AudioOutputDevices}"
                        SelectedItem="{Binding AudioOutputDevice}"
                        IsEditable="True" Text="{Binding AudioOutputDevice}"
                        PlaceholderText="Select output device"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
            <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                    Content="↻" ToolTip.Tip="Refresh device list"
                    Padding="10,6" VerticalAlignment="Bottom" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- PTT -->
      <Border Grid.Row="3" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
              CornerRadius="6" Padding="14" Background="{DynamicResource CardBgBrush}">
        <StackPanel Spacing="10">
          <TextBlock Text="PTT (Push to Talk)" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
            <StackPanel Spacing="2">
              <TextBlock Text="PTT method" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox ItemsSource="{Binding AvailablePttMethods}"
                        SelectedItem="{Binding PttMethod}"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2" IsVisible="{Binding ShowSerialPortPicker}">
              <TextBlock Text="PTT serial port" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                         ToolTip.Tip="The serial port whose RTS or DTR pin will be used for PTT. For DigiRig, this is usually the CAT/control port." />
              <ComboBox ItemsSource="{Binding AvailableSerialPorts}"
                        SelectedItem="{Binding PttSerialPort}"
                        IsEditable="True" Text="{Binding PttSerialPort}"
                        PlaceholderText="Select serial port"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
          </Grid>
          <CheckBox Content="Enable RF transmit"
                    IsChecked="{Binding TransmitEnabled}"
                    ToolTip.Tip="Allow the managed modem to transmit on RF. The transmit safety authority also applies — exercise mode will block transmit even when this is enabled." />
        </StackPanel>
      </Border>

      <!-- KISS port -->
      <Border Grid.Row="4" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
              CornerRadius="6" Padding="14" Background="{DynamicResource CardBgBrush}">
        <StackPanel Spacing="8">
          <TextBlock Text="Advanced" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
          <StackPanel Spacing="2">
            <TextBlock Text="KISS TCP port" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                       ToolTip.Tip="The port Direwolf listens on for KISS TCP connections. Default is 8001. Change only if you have a port conflict." />
            <NumericUpDown Value="{Binding KissPort}" Minimum="1024" Maximum="65535" Width="120"
                           HorizontalAlignment="Left" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Save / Revert -->
      <Grid Grid.Row="5" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
        <Button Command="{Binding SaveCommand}" Content="Save" Padding="14,6" />
        <Button Grid.Column="1" Command="{Binding RevertCommand}" Content="Revert" Padding="10,6" />
        <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>

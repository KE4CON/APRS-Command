<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             x:Class="Aprs.Desktop.Views.MapView"
             x:DataType="vm:MapViewModel">
  <Border BorderBrush="{DynamicResource AccentTealBrush}"
          BorderThickness="1"
          CornerRadius="6"
          ClipToBounds="True">
    <Grid>
      <mapsui:MapControl x:Name="MapControl">
        <mapsui:MapControl.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Assign tactical callsign…"
                      Command="{Binding AssignTacticalCommand}"
                      IsEnabled="{Binding HasSelectedStation}" />
            <Separator />
            <MenuItem Header="⊙ Draw rings from this station"
                      Command="{Binding SetRingsHereCommand}"
                      IsEnabled="{Binding HasSelectedStation}"
                      ToolTip.Tip="Centre the range rings on the selected station" />
            <MenuItem Header="⊙ Draw rings from my station"
                      Command="{Binding ClearCustomRingCenterCommand}"
                      ToolTip.Tip="Reset range rings to your own station position" />
          </ContextMenu>
        </mapsui:MapControl.ContextMenu>
      </mapsui:MapControl>

      <!-- Base map selector — top left -->
      <Border HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="12"
              Background="{DynamicResource TextTitleBarBrush}"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="5"
              Padding="8,6">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Base map:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
          <ComboBox x:Name="BaseMapSelector"
                    SelectedIndex="0"
                    MinWidth="170"
                    SelectionChanged="BaseMapSelector_SelectionChanged">
            <ComboBoxItem>OpenStreetMap</ComboBoxItem>
            <ComboBoxItem>USGS Topo</ComboBoxItem>
            <ComboBoxItem>USGS Imagery</ComboBoxItem>
            <ComboBoxItem>USGS Imagery + Topo</ComboBoxItem>
          </ComboBox>
        </StackPanel>
      </Border>

      <!-- Create Object overlay — top right, only shown during object placement -->
      <Border HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="12"
              Background="{DynamicResource TextTitleBarBrush}"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="5"
              Padding="10,8"
              IsVisible="{Binding IsCreateObjectMode}">
        <StackPanel Spacing="6">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock Text="{Binding ObjectPlacementStatus}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="260" />
            <Button Grid.Column="1"
                    Content="Create Object"
                    Command="{Binding BeginCreateObjectCommand}" />
          </Grid>
          <TextBlock Text="Select an object, then click the map to move it locally."
                     FontSize="11"
                     Foreground="{DynamicResource TextMutedBrush}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Station selection panels — bottom left -->
      <Border x:Name="EmptySelectionPanel"
              HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              Margin="12"
              Background="{DynamicResource TextTitleBarBrush}"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="5"
              Padding="10,8">
        <TextBlock Text="Select a station marker" Foreground="{DynamicResource TextSecondaryBrush}" />
      </Border>

      <Border x:Name="StationDetailsPanel"
              HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              Margin="12"
              Background="{DynamicResource TextTitleBarBrush}"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="5"
              Padding="12"
              MaxWidth="430"
              IsVisible="False">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="1">
              <TextBlock Text="{Binding SelectedStationDetails.DisplayName}"
                         FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.Callsign}"
                         Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
            </StackPanel>
            <Button Grid.Column="1" Padding="8,4" Click="ClearSelectionButton_Click">
              <TextBlock Text="Clear" />
            </Button>
          </Grid>

          <UniformGrid Grid.Row="1" Columns="2" Rows="4">
            <StackPanel Margin="0,0,12,5">
              <TextBlock Text="Symbol" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.SymbolDescription}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Margin="0,0,0,5">
              <TextBlock Text="Grid" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.MaidenheadGridSquare}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Margin="0,0,12,5">
              <TextBlock Text="Coordinates" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.Coordinates}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Margin="0,0,0,5">
              <TextBlock Text="Heard" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.LastHeardAge}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Margin="0,0,12,5">
              <TextBlock Text="Speed / Course" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.SpeedCourse}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Margin="0,0,0,5">
              <TextBlock Text="Altitude" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.Altitude}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Margin="0,0,12,5">
              <TextBlock Text="Source" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.PacketSource}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Margin="0,0,0,5">
              <TextBlock Text="Packets" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <TextBlock Text="{Binding SelectedStationDetails.PacketCount}" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </UniformGrid>

          <StackPanel Grid.Row="2" Spacing="2">
            <TextBlock Text="Path" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding SelectedStationDetails.LastPath}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
            <TextBlock Text="Heard by" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,5,0,0" />
            <TextBlock Text="{Binding SelectedStationDetails.HeardBy}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
            <Border IsVisible="{Binding SelectedStationDetails.HasDuplicates}"
                    Background="#fff7ed" CornerRadius="4" Padding="6,3" Margin="0,5,0,0"
                    HorizontalAlignment="Left">
              <TextBlock Foreground="#c2410c" FontSize="10" FontWeight="SemiBold">
                <Run Text="⚡ " /><Run Text="{Binding SelectedStationDetails.DuplicatePacketCount}" /><Run Text=" duplicate packets detected" />
              </TextBlock>
            </Border>
            <TextBlock Text="Comment" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,5,0,0" />
            <TextBlock Text="{Binding SelectedStationDetails.Comment}" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
          </StackPanel>

          <StackPanel Grid.Row="3" Spacing="2">
            <TextBlock Text="Last Raw Packet" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding SelectedStationDetails.LastRawPacket}"
                       Foreground="{DynamicResource TitleBarBorderBrush}"
                       FontFamily="Consolas,Menlo,Monospace"
                       FontSize="11"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Radar animation scrubber — bottom centre, visible only when radar is on and frames are loaded -->
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Margin="0,0,0,16"
              IsVisible="{Binding ShowAnimationControls}"
              Background="{DynamicResource TextTitleBarBrush}"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="20"
              Padding="14,8">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Button Command="{Binding RadarPreviousFrameCommand}"
                  Content="◀" Padding="0" Width="28" Height="28"
                  FontSize="12" CornerRadius="14"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  ToolTip.Tip="Previous frame" />
          <Button Command="{Binding ToggleRadarAnimationCommand}"
                  Content="{Binding AnimationButtonLabel}"
                  Padding="0" Width="34" Height="28"
                  FontSize="14" CornerRadius="14"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  ToolTip.Tip="Play/pause radar animation" />
          <Button Command="{Binding RadarNextFrameCommand}"
                  Content="▶" Padding="0" Width="28" Height="28"
                  FontSize="12" CornerRadius="14"
                  Background="Transparent" BorderThickness="0"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  ToolTip.Tip="Next frame" />
          <Border Width="1" Background="{DynamicResource TextSidebarBrush}" Opacity="0.3" Margin="2,2" />
          <StackPanel VerticalAlignment="Center" Spacing="0" MinWidth="60">
            <TextBlock Text="{Binding RadarFrameTime}" FontSize="12" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="{Binding RadarFrameLabel}" FontSize="9"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>

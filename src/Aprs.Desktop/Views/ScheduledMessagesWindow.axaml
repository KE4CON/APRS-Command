<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.ScheduledMessagesWindow"
        x:DataType="vm:ScheduledMessagesViewModel"
        Title="Scheduled Messages"
        Width="600" Height="480"
        MinWidth="500" MinHeight="380"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource AppBgBrush}">

    <!-- Compose -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}" Padding="16,12">
      <StackPanel Spacing="10">
        <TextBlock Text="Scheduled Messages" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextTitleBarBrush}" />
        <TextBlock FontSize="10" Foreground="{DynamicResource TextSidebarBrush}"
                   Text="Compose a message now and schedule it for future delivery. The app must be running at send time." />

        <Grid ColumnDefinitions="*,110,90" ColumnSpacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="Recipient" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
            <TextBox Text="{Binding Recipient}" Watermark="e.g. W4ABC" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="2">
            <TextBlock Text="Send date" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
            <TextBox Text="{Binding SendDate}" Watermark="MM/dd/yyyy" />
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="2">
            <TextBlock Text="Send time" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
            <TextBox Text="{Binding SendTime}" Watermark="HH:mm" />
          </StackPanel>
        </Grid>

        <StackPanel Spacing="2">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Message" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" FontSize="9"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center">
              <Run Text="{Binding CharCount}" /><Run Text="/67" />
            </TextBlock>
          </Grid>
          <TextBox Text="{Binding Body}" Watermark="Message text (max 67 characters)"
                   MaxLength="67" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Scheduled messages list -->
    <Grid Grid.Row="1" RowDefinitions="Auto,*">
      <Border Grid.Row="0" Padding="14,6">
        <TextBlock Text="Scheduled messages" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Messages}"
               SelectedItem="{Binding SelectedMessage}"
               Background="{DynamicResource AppBgBrush}">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ScheduledMessageRowViewModel">
            <Grid ColumnDefinitions="90,100,*,90" Margin="4,3">
              <TextBlock Text="{Binding Recipient}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBlueMidBrush}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding SendAtLocal}" FontSize="10"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding Body}" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Column="3" Text="{Binding StatusLabel}" FontSize="10"
                         Foreground="{Binding StatusColor}" VerticalAlignment="Center"
                         HorizontalAlignment="Right" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>

    <!-- Footer -->
    <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource AppBgAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
        <TextBlock Text="{Binding StatusText}" FontSize="10"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Command="{Binding ScheduleCommand}"
                Content="⏰ Schedule" Padding="12,5" />
        <Button Grid.Column="2" Command="{Binding CancelCommand}"
                Content="Cancel selected" Padding="8,5" FontSize="10"
                IsEnabled="{Binding SelectedMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <Button Grid.Column="3" x:Name="CloseButton" Content="Close" Padding="12,5" />
      </Grid>
    </Border>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.NetControlView"
        x:DataType="vm:NetControlViewModel"
        Title="Net Control Roster"
        Width="820" Height="580"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Background="{DynamicResource AppBgBrush}">

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}" Padding="14,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBox Text="{Binding NetName}"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextTitleBarBrush}"
                   Background="Transparent" BorderThickness="0"
                   Watermark="Net name..." />
          <TextBlock Text="{Binding SummaryText}"
                     FontSize="11" Foreground="{DynamicResource TextSidebarBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <CheckBox Content="Auto-add heard stations"
                    IsChecked="{Binding AutoAddHeardStations}"
                    Foreground="{DynamicResource TextSidebarBrush}"
                    FontSize="11" />
          <Button Command="{Binding RefreshCommand}" Content="↻ Refresh"
                  Padding="10,5" FontSize="11" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Add callsign + filter bar -->
    <Border Grid.Row="1" Padding="10,8" BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="0,0,0,1" Background="{DynamicResource HeaderBgBrush}">
      <Grid ColumnDefinitions="*,Auto,20,*" ColumnSpacing="6">
        <TextBox Grid.Column="0" Text="{Binding NewCallsign}"
                 Watermark="Enter callsign to add (e.g. W4ABC)"
                 x:Name="CallsignInput" />
        <Button Grid.Column="1" Command="{Binding AddCallsignCommand}"
                Content="Add to Roster" Padding="12,6" />
        <TextBox Grid.Column="3" Text="{Binding FilterText}"
                 Watermark="🔍 Filter roster..." />
      </Grid>
    </Border>

    <!-- Roster list -->
    <Grid Grid.Row="2" ColumnDefinitions="*,280">

      <!-- Station list -->
      <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0">
        <ListBox ItemsSource="{Binding FilteredRoster}"
                 SelectedItem="{Binding SelectedEntry}"
                 Background="{DynamicResource SurfaceBgBrush}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:NetControlRosterEntry">
              <Grid ColumnDefinitions="32,*,80,80,80" Margin="4,3">
                <!-- Check-in status icon -->
                <TextBlock Text="{Binding StatusIcon}"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{Binding StatusColor}"
                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                <!-- Callsign + assignment -->
                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding DisplayName}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding Assignment}"
                             FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                             TextTrimming="CharacterEllipsis"
                             IsVisible="{Binding Assignment, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  <TextBlock Text="{Binding Comment}"
                             FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                             TextTrimming="CharacterEllipsis"
                             IsVisible="{Binding Assignment, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                </StackPanel>
                <!-- Resource status badge -->
                <Border Grid.Column="2" CornerRadius="3" Padding="4,2"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                  <TextBlock Text="{Binding ResourceStatusLabel}"
                             FontSize="9" FontWeight="SemiBold"
                             Foreground="{Binding ResourceStatusColor}" />
                </Border>
                <!-- Check-in time -->
                <TextBlock Grid.Column="3" Text="{Binding CheckedInAtText}"
                           FontSize="10" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <!-- Last heard -->
                <TextBlock Grid.Column="4" Text="{Binding LastHeardText}"
                           FontSize="10" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Right" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <!-- Detail panel -->
      <Border Grid.Column="1" Padding="14" Background="{DynamicResource CardBgBrush}">
        <StackPanel Spacing="10" IsVisible="{Binding HasSelection}">
          <TextBlock Text="{Binding SelectedEntry.Callsign}"
                     FontSize="20" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="{Binding SelectedEntry.PositionText}"
                     FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <TextBlock Text="{Binding SelectedEntry.Comment}"
                     FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap" />

          <Border Height="1" Background="{DynamicResource AppBorderBrush}" Margin="0,4" />

          <!-- Status buttons -->
          <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <StackPanel Spacing="6">
            <Button Command="{Binding CheckInCommand}" HorizontalAlignment="Stretch"
                    Padding="0,8" Content="✓ Check In" />
            <Button Command="{Binding StandbyCommand}" HorizontalAlignment="Stretch"
                    Padding="0,8" Content="⏸ Standby" />
            <Button Command="{Binding DepartCommand}" HorizontalAlignment="Stretch"
                    Padding="0,8" Content="✗ Departed" />
          </StackPanel>

          <Border Height="1" Background="{DynamicResource AppBorderBrush}" Margin="0,4" />

          <!-- Resource status (ICS operational status) -->
          <TextBlock Text="Resource Status" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <Border Background="{DynamicResource AppBgAltBrush}" CornerRadius="4" Padding="8,6">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
              <TextBlock FontSize="18" HorizontalAlignment="Center"
                         Text="{Binding SelectedEntry.ResourceStatusIcon}"
                         Foreground="{Binding SelectedEntry.ResourceStatusColor}" />
              <TextBlock FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"
                         Text="{Binding SelectedEntry.ResourceStatusLabel}"
                         Foreground="{Binding SelectedEntry.ResourceStatusColor}" />
            </StackPanel>
          </Border>
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="4" RowSpacing="4">
            <Button Grid.Column="0" Command="{Binding SetAvailableCommand}"
                    Content="● Available" Padding="4,5" FontSize="10"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Station is available for assignment" />
            <Button Grid.Column="1" Command="{Binding SetAssignedCommand}"
                    Content="→ Assigned" Padding="4,5" FontSize="10"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Station has been given an assignment" />
            <Button Grid.Row="1" Grid.Column="0" Command="{Binding SetOnSceneCommand}"
                    Content="★ On Scene" Padding="4,5" FontSize="10"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Station is at the assigned location" />
            <Button Grid.Row="1" Grid.Column="1" Command="{Binding SetReturningCommand}"
                    Content="← Returning" Padding="4,5" FontSize="10"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Station has completed task and is returning" />
            <Button Grid.Row="2" Grid.ColumnSpan="2" Command="{Binding SetOutOfServiceCommand}"
                    Content="○ Out of Service" Padding="4,5" FontSize="10"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Station is unavailable for assignment" />
          </Grid>

          <!-- Assignment text -->
          <TextBlock Text="Current assignment" FontSize="10"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <TextBox Text="{Binding SelectedEntry.Assignment}"
                   Watermark="Describe the assignment..."
                   FontSize="10" />

          <!-- Resource typing -->
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <StackPanel Spacing="2">
              <TextBlock Text="Resource type (ICS)" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}"
                         ToolTip.Tip="ICS resource typing: Type 1 = highest capability, Type 4 = basic. Used by incident commanders to request resources by capability level." />
              <ComboBox ItemsSource="{Binding AvailableResourceTypes}"
                        SelectedItem="{Binding SelectedEntry.ResourceType}"
                        HorizontalAlignment="Stretch" FontSize="10" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Category" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}"
                         ToolTip.Tip="Resource category e.g. Communications, Medical, Logistics, Operations" />
              <TextBox Text="{Binding SelectedEntry.ResourceCategory}"
                       Watermark="e.g. Communications"
                       FontSize="10" />
            </StackPanel>
          </Grid>

          <Border Height="1" Background="{DynamicResource AppBorderBrush}" Margin="0,4" />

          <!-- Notes -->
          <TextBlock Text="Notes" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <TextBox Text="{Binding SelectedEntry.Notes}"
                   Watermark="Add notes about this station..."
                   AcceptsReturn="True" Height="60" />

          <Button Command="{Binding RemoveCommand}" HorizontalAlignment="Stretch"
                  Padding="0,6" Content="Remove from roster"
                  Foreground="{DynamicResource ErrorTextBrush}" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="3" Padding="10,5" Background="{DynamicResource HeaderBgBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <TextBlock Text="{Binding StatusText}" FontSize="11"
                 Foreground="{DynamicResource TextMutedBrush}" />
    </Border>

    <!-- Bottom toolbar -->
    <Border Grid.Row="4" Padding="10,8" Background="{DynamicResource AppBgAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Button Command="{Binding ClearAllCommand}" Content="Clear All"
              HorizontalAlignment="Right" Padding="12,6" />
    </Border>

  </Grid>
</Window>

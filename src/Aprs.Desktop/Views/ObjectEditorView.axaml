<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             xmlns:mapping="using:Aprs.Mapping"
             x:Class="Aprs.Desktop.Views.ObjectEditorView"
             x:DataType="vm:ObjectEditorViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
        RowSpacing="8">
    <Grid ColumnDefinitions="*,*,Auto,Auto"
          ColumnSpacing="8">
      <StackPanel>
        <TextBlock Text="Object"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}" />
        <TextBox Text="{Binding ObjectName}" />
      </StackPanel>
      <StackPanel Grid.Column="1">
        <TextBlock Text="Owner"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}" />
        <TextBox Text="{Binding OwnerCallsign}" />
      </StackPanel>
      <CheckBox Grid.Column="2"
                Content="Alive"
                IsChecked="{Binding IsAlive}"
                VerticalAlignment="Bottom" />
      <CheckBox Grid.Column="3"
                Content="Killed"
                IsChecked="{Binding IsKilled}"
                VerticalAlignment="Bottom" />
    </Grid>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*,Auto,Auto,Auto"
          ColumnSpacing="8">
      <StackPanel>
        <TextBlock Text="Latitude"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}" />
        <TextBox Text="{Binding Latitude}" />
      </StackPanel>
      <StackPanel Grid.Column="1">
        <TextBlock Text="Longitude"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}" />
        <TextBox Text="{Binding Longitude}" />
      </StackPanel>
      <StackPanel Grid.Column="2" Grid.ColumnSpan="3" Spacing="4">
        <TextBlock Text="Symbol"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}"
                   ToolTip.Tip="Click to choose the object's map icon. The symbol code is set automatically." />
        <ListBox ItemsSource="{Binding AvailableSymbols}"
                 SelectedItem="{Binding SelectedSymbol}"
                 MaxHeight="80"
                 BorderBrush="{DynamicResource TextSidebarBrush}"
                 BorderThickness="1">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="mapping:AprsSymbol">
              <Border Width="40" Margin="1" Padding="3,4" CornerRadius="3"
                      ToolTip.Tip="{Binding Description}">
                <TextBlock Text="{Binding FallbackDisplayText}"
                           FontSize="14" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AccentBlueBrush}" />
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <Border Background="{DynamicResource AccentBlueBgBrush}" BorderBrush="{DynamicResource AccentBlueBorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="8,5">
          <TextBlock Text="{Binding SymbolDisplay}"
                     FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBlueBrush}" />
        </Border>
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="2">
      <TextBlock Text="Comment"
                 FontSize="11"
                 Foreground="{DynamicResource TextMutedBrush}" />
      <TextBox Text="{Binding Comment}" />
    </StackPanel>

    <Grid Grid.Row="3"
          ColumnDefinitions="*,Auto,Auto,Auto"
          ColumnSpacing="10">
      <StackPanel>
        <TextBlock Text="Interval"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}" />
        <TextBox Watermark="placeholder"
                 Text="{Binding TransmitIntervalMinutes}" />
      </StackPanel>
      <CheckBox Grid.Column="1"
                Content="APRS-IS TX"
                IsChecked="{Binding AprsIsTransmitEnabled}"
                VerticalAlignment="Bottom" />
      <CheckBox Grid.Column="2"
                Content="RF TX"
                IsChecked="{Binding RfTransmitEnabled}"
                VerticalAlignment="Bottom" />
      <CheckBox Grid.Column="3"
                Content="Adopted"
                IsChecked="{Binding IsAdopted}"
                ToolTip.Tip="Adopted means your station has taken ownership of this object, which was originally created by another station. Your station will transmit it to keep it alive on the network."
                VerticalAlignment="Bottom" />
    </Grid>

    <Border Grid.Row="4"
            BorderBrush="{DynamicResource AccentBlueBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Background="{DynamicResource AccentBlueBgBrush}"
            Padding="8"
            Margin="0,0,0,4">
      <StackPanel Spacing="6">
        <CheckBox Content="Area Object (encode shape in comment using APRS area object format)"
                  IsChecked="{Binding IsAreaObject}"
                  FontWeight="SemiBold" />
        <Grid ColumnDefinitions="*,*,Auto,Auto"
              ColumnSpacing="8"
              IsVisible="{Binding IsAreaObject}">
          <StackPanel>
            <TextBlock Text="Shape" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            <ComboBox ItemsSource="{Binding AreaShapes}"
                      SelectedIndex="3"
                      DisplayMemberBinding="{Binding Label}" />
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="Color" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            <ComboBox ItemsSource="{Binding AreaColors}"
                      SelectedIndex="1"
                      DisplayMemberBinding="{Binding Label}" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Width (km)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            <NumericUpDown Value="{Binding AreaWidthKm}" Minimum="0.1" Maximum="99" Increment="0.5"
                           FormatString="0.0" Width="90" />
          </StackPanel>
          <StackPanel Grid.Column="3">
            <TextBlock Text="Height (km)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
            <NumericUpDown Value="{Binding AreaHeightKm}" Minimum="0.1" Maximum="99" Increment="0.5"
                           FormatString="0.0" Width="90" />
          </StackPanel>
        </Grid>
        <TextBlock Text="Area objects use the \l symbol and encode shape dimensions in the comment field per APRS spec §11."
                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                   IsVisible="{Binding IsAreaObject}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Grid.Row="5"
            BorderBrush="{DynamicResource TextSidebarBrush}"
            BorderThickness="1"
            BorderBrush="{DynamicResource TextSidebarBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Background="{DynamicResource TextTitleBarBrush}"
            Padding="8">
      <StackPanel Spacing="4">
        <TextBlock Text="Packet preview"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}" />
        <TextBlock Text="{Binding PacketPreview}"
                   FontFamily="Consolas, Menlo, monospace"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding ValidationSummary}"
                   Foreground="{DynamicResource ErrorBorderBrush}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding WarningSummary}"
                   Foreground="{DynamicResource WarnTextStrongBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             xmlns:mapping="using:Aprs.Mapping"
             x:Class="Aprs.Desktop.Views.ObjectEditorView"
             x:DataType="vm:ObjectEditorViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
        RowSpacing="8">
    <Grid ColumnDefinitions="*,*,Auto,Auto"
          ColumnSpacing="8">
      <StackPanel>
        <TextBlock Text="Object"
                   FontSize="11"
                   Foreground="#64748B" />
        <TextBox Text="{Binding ObjectName}" />
      </StackPanel>
      <StackPanel Grid.Column="1">
        <TextBlock Text="Owner"
                   FontSize="11"
                   Foreground="#64748B" />
        <TextBox Text="{Binding OwnerCallsign}" />
      </StackPanel>
      <CheckBox Grid.Column="2"
                Content="Alive"
                IsChecked="{Binding IsAlive}"
                VerticalAlignment="Bottom" />
      <CheckBox Grid.Column="3"
                Content="Killed"
                IsChecked="{Binding IsKilled}"
                VerticalAlignment="Bottom" />
    </Grid>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*,Auto,Auto,Auto"
          ColumnSpacing="8">
      <StackPanel>
        <TextBlock Text="Latitude"
                   FontSize="11"
                   Foreground="#64748B" />
        <TextBox Text="{Binding Latitude}" />
      </StackPanel>
      <StackPanel Grid.Column="1">
        <TextBlock Text="Longitude"
                   FontSize="11"
                   Foreground="#64748B" />
        <TextBox Text="{Binding Longitude}" />
      </StackPanel>
      <StackPanel Grid.Column="2" Grid.ColumnSpan="3" Spacing="4">
        <TextBlock Text="Symbol"
                   FontSize="11"
                   Foreground="#64748B"
                   ToolTip.Tip="Click to choose the object's map icon. The symbol code is set automatically." />
        <ListBox ItemsSource="{Binding AvailableSymbols}"
                 SelectedItem="{Binding SelectedSymbol}"
                 MaxHeight="80"
                 BorderBrush="#CBD5E1"
                 BorderThickness="1">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="mapping:AprsSymbol">
              <Border Width="40" Margin="1" Padding="3,4" CornerRadius="3"
                      ToolTip.Tip="{Binding Description}">
                <TextBlock Text="{Binding FallbackDisplayText}"
                           FontSize="14" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#1D4ED8" />
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                CornerRadius="4" Padding="8,5">
          <TextBlock Text="{Binding SymbolDisplay}"
                     FontSize="11" FontWeight="SemiBold" Foreground="#1D4ED8" />
        </Border>
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="2">
      <TextBlock Text="Comment"
                 FontSize="11"
                 Foreground="#64748B" />
      <TextBox Text="{Binding Comment}" />
    </StackPanel>

    <Grid Grid.Row="3"
          ColumnDefinitions="*,Auto,Auto,Auto"
          ColumnSpacing="10">
      <StackPanel>
        <TextBlock Text="Interval"
                   FontSize="11"
                   Foreground="#64748B" />
        <TextBox Watermark="placeholder"
                 Text="{Binding TransmitIntervalMinutes}" />
      </StackPanel>
      <CheckBox Grid.Column="1"
                Content="APRS-IS TX"
                IsChecked="{Binding AprsIsTransmitEnabled}"
                VerticalAlignment="Bottom" />
      <CheckBox Grid.Column="2"
                Content="RF TX"
                IsChecked="{Binding RfTransmitEnabled}"
                VerticalAlignment="Bottom" />
      <CheckBox Grid.Column="3"
                Content="Adopted"
                IsChecked="{Binding IsAdopted}"
                ToolTip.Tip="Adopted means your station has taken ownership of this object, which was originally created by another station. Your station will transmit it to keep it alive on the network."
                VerticalAlignment="Bottom" />
    </Grid>

    <Border Grid.Row="4"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="4"
            Background="#F8FAFC"
            Padding="8">
      <StackPanel Spacing="4">
        <TextBlock Text="Packet preview"
                   FontSize="11"
                   Foreground="#64748B" />
        <TextBlock Text="{Binding PacketPreview}"
                   FontFamily="Consolas, Menlo, monospace"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding ValidationSummary}"
                   Foreground="#B91C1C"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding WarningSummary}"
                   Foreground="#92400E"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

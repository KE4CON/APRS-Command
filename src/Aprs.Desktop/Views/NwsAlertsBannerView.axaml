<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.NwsAlertsBannerView"
             x:DataType="vm:NwsAlertsViewModel"
             IsVisible="{Binding HasAlerts}">
  <Border Padding="12,8" Background="{Binding BannerBg}"
          BorderBrush="{Binding BannerColor}" BorderThickness="0,0,0,2">
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="{Binding SummaryText}"
                 FontSize="12" FontWeight="SemiBold"
                 Foreground="{Binding BannerColor}"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="1" Text="{Binding LastRefreshedText}"
                 FontSize="10" Foreground="{Binding BannerColor}"
                 VerticalAlignment="Center" Opacity="0.7" />
    </Grid>
  </Border>
</UserControl>

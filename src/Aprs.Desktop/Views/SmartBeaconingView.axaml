<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.SmartBeaconingView"
             x:DataType="vm:SmartBeaconingViewModel">
  <ScrollViewer Padding="16,12">
    <StackPanel Spacing="14" MaxWidth="480">

      <TextBlock Text="Smart Beaconing" FontSize="14" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />

      <TextBlock TextWrapping="Wrap" FontSize="11"
                 Foreground="{DynamicResource TextSubtleBrush}"
                 Text="Smart beaconing adjusts your beacon rate based on speed and direction changes. Beacon frequently when moving fast or turning, slowly when stationary. Requires GPS." />

      <CheckBox IsChecked="{Binding Enabled}" Content="Enable smart beaconing" FontSize="12" />

      <Border Height="1" Background="{DynamicResource AppBorderBrush}" />

      <!-- Speed thresholds -->
      <TextBlock Text="Speed thresholds" FontSize="11" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <Grid ColumnDefinitions="*,20,*" ColumnSpacing="8">
        <StackPanel Spacing="3">
          <TextBlock Text="Low speed (knots)" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
          <NumericUpDown Value="{Binding LowSpeedThresholdKnots}" Minimum="1" Maximum="20"
                         Increment="1" FormatString="F0" />
          <TextBlock Text="Below this = slow rate" FontSize="9"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
        <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                   HorizontalAlignment="Center" FontSize="14"
                   Foreground="{DynamicResource TextMutedBrush}" />
        <StackPanel Grid.Column="2" Spacing="3">
          <TextBlock Text="High speed (knots)" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
          <NumericUpDown Value="{Binding HighSpeedThresholdKnots}" Minimum="10" Maximum="200"
                         Increment="5" FormatString="F0" />
          <TextBlock Text="Above this = fast rate" FontSize="9"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
      </Grid>

      <!-- Beacon rates -->
      <TextBlock Text="Beacon rates" FontSize="11" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
        <StackPanel Spacing="3">
          <TextBlock Text="Slow rate (minutes)" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
          <NumericUpDown Value="{Binding SlowRateMinutes}" Minimum="5" Maximum="60"
                         Increment="5" FormatString="0" />
          <TextBlock Text="When stationary or slow" FontSize="9"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="3">
          <TextBlock Text="Fast rate (minutes)" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
          <NumericUpDown Value="{Binding FastRateMinutes}" Minimum="1" Maximum="15"
                         Increment="1" FormatString="0" />
          <TextBlock Text="When moving fast" FontSize="9"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
      </Grid>

      <!-- Turn threshold -->
      <TextBlock Text="Corner pegging" FontSize="11" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <StackPanel Spacing="3" MaxWidth="200">
        <TextBlock Text="Minimum turn angle (degrees)" FontSize="10"
                   Foreground="{DynamicResource TextMutedBrush}" />
        <NumericUpDown Value="{Binding MinimumTurnAngleDegrees}" Minimum="10" Maximum="120"
                       Increment="5" FormatString="F0" />
        <TextBlock Text="Turn larger than this triggers a beacon" FontSize="9"
                   Foreground="{DynamicResource TextMutedBrush}" />
      </StackPanel>

      <!-- Where to apply -->
      <TextBlock Text="Apply smart beaconing to" FontSize="11" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <StackPanel Spacing="4">
        <CheckBox IsChecked="{Binding EnabledForAprsIs}" Content="APRS-IS (internet)" />
        <CheckBox IsChecked="{Binding EnabledForRf}" Content="RF (radio — requires TNC or managed modem)" />
      </StackPanel>

      <!-- Buttons -->
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
        <Button Command="{Binding SaveCommand}" Content="Save" Padding="16,7" />
        <Button Command="{Binding ResetDefaultsCommand}" Content="Reset defaults" Padding="12,7" />
      </StackPanel>

      <TextBlock Text="{Binding StatusText}" FontSize="11"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap" />

    </StackPanel>
  </ScrollViewer>
</UserControl>

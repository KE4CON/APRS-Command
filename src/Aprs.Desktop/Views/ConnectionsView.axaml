<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.ConnectionsView"
             x:DataType="vm:ConnectionsViewModel">
  <UserControl.Resources>
    <vm:ConnectionPortTypeConverter x:Key="PortTypeConverter" />
  </UserControl.Resources>
  <Grid RowDefinitions="Auto,*,Auto,Auto"
        RowSpacing="12">

    <!-- Header -->
    <StackPanel Spacing="2">
      <TextBlock Text="Connections"
                 FontSize="18"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Text="The ports APRS Command connects through. Run more than one at once (for example a radio port and APRS-IS together)."
                 Foreground="{DynamicResource TextSubtleBrush}"
                 FontSize="12"
                 TextWrapping="Wrap" />
    </StackPanel>

    <!-- Body: port list (left) + editor (right) -->
    <Grid Grid.Row="1"
          ColumnDefinitions="300,*"
          ColumnSpacing="12">

      <!-- Left: the list, plus add/remove -->
      <Grid Grid.Column="0"
            RowDefinitions="*,Auto"
            RowSpacing="8">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{DynamicResource SurfaceBgBrush}">
          <ListBox ItemsSource="{Binding Ports}"
                   SelectedItem="{Binding SelectedPort}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ConnectionPortRowViewModel">
                <StackPanel Spacing="2"
                            Margin="2,4">
                  <TextBlock Text="{Binding Name}"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding TypeDisplay}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="6">
          <ComboBox ItemsSource="{Binding AvailablePortTypes}"
                    SelectedItem="{Binding NewPortType}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Converter={StaticResource PortTypeConverter}}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Grid.Column="1"
                  Command="{Binding AddPortCommand}"
                  Padding="10,6"
                  Content="Add" />
          <Button Grid.Column="2"
                  Command="{Binding RemoveSelectedPortCommand}"
                  Padding="10,6"
                  Content="Remove" />
        </Grid>
      </Grid>

      <!-- Right: editor for the selected port -->
      <Border Grid.Column="1"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12"
              Background="{DynamicResource TextTitleBarBrush}"
              IsEnabled="{Binding HasSelection}">
        <ScrollViewer>
          <StackPanel Spacing="12">

            <!-- Common fields -->
            <StackPanel Spacing="2">
              <TextBlock Text="Name"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
              <TextBox Text="{Binding SelectedPort.Name}" />
            </StackPanel>

            <TextBlock Text="{Binding SelectedPort.TypeDisplay}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <StackPanel Orientation="Horizontal"
                        Spacing="18">
              <CheckBox Content="Enabled"
                        IsChecked="{Binding SelectedPort.Enabled}" />
              <CheckBox Content="Receive"
                        IsChecked="{Binding SelectedPort.ReceiveEnabled}" />
              <CheckBox Content="Transmit"
                        IsChecked="{Binding SelectedPort.TransmitEnabled}" />
            </StackPanel>

            <!-- Network TNC (KISS-TCP) / managed local modem -->
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10"
                  IsVisible="{Binding SelectedPort.IsNetwork}">
              <StackPanel Spacing="2">
                <TextBlock Text="Host"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding SelectedPort.NetworkHost}" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Spacing="2">
                <TextBlock Text="Port"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <NumericUpDown Value="{Binding SelectedPort.NetworkPort}"
                               Minimum="1"
                               Maximum="65535"
                               Width="130" />
              </StackPanel>
            </Grid>

            <!-- AGWPE -->
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10"
                  IsVisible="{Binding SelectedPort.IsAgwpe}">
              <StackPanel Spacing="2">
                <TextBlock Text="Host"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding SelectedPort.AgwpeHost}" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Spacing="2">
                <TextBlock Text="Port"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <NumericUpDown Value="{Binding SelectedPort.AgwpePort}"
                               Minimum="1"
                               Maximum="65535"
                               Width="130" />
              </StackPanel>
            </Grid>

            <!-- Serial KISS (hardware TNC) -->
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10"
                  IsVisible="{Binding SelectedPort.IsSerial}">
              <StackPanel Spacing="2">
                <TextBlock Text="Serial port"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <ComboBox ItemsSource="{Binding SelectedPort.AvailableSerialPorts}"
                          SelectedItem="{Binding SelectedPort.SerialPortName}"
                          HorizontalAlignment="Stretch"
                          IsEditable="True"
                          Text="{Binding SelectedPort.SerialPortName}"
                          PlaceholderText="e.g. /dev/tty.usbserial or COM3" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Spacing="2">
                <TextBlock Text="Baud"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <NumericUpDown Value="{Binding SelectedPort.BaudRate}"
                               Minimum="300"
                               Maximum="115200"
                               Increment="1200"
                               Width="130" />
              </StackPanel>
            </Grid>

            <!-- APRS-IS -->
            <StackPanel Spacing="8"
                        IsVisible="{Binding SelectedPort.IsAprsIs}">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <StackPanel Spacing="2">
                  <TextBlock Text="Server"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBox Text="{Binding SelectedPort.AprsIsServer}"
                           Watermark="e.g. rotate.aprs2.net" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="2">
                  <TextBlock Text="Port"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <NumericUpDown Value="{Binding SelectedPort.AprsIsPort}"
                                 Minimum="1"
                                 Maximum="65535"
                                 Width="130" />
                </StackPanel>
              </Grid>
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="10">
                <StackPanel Spacing="2">
                  <TextBlock Text="Passcode"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBox Text="{Binding SelectedPort.AprsIsPasscode}"
                           Width="130"
                           Watermark="-1 = RX only"
                           ToolTip.Tip="Your APRS-IS passcode — a number calculated from your callsign. Required to transmit beacons and messages. Enter -1 for receive-only operation. Find your passcode at: apps.magicbug.co.uk/passcode" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Spacing="2">
                  <TextBlock Text="Filter (optional)"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBox Text="{Binding SelectedPort.AprsIsFilter}"
                           Watermark="e.g. m/100"
                           ToolTip.Tip="Advanced: override the automatic geographic filter. Leave blank to use the radius set in Station Setup. Custom example: r/41.97/-88.45/200 receives stations within 200 km of that location. The number is always in kilometers regardless of your unit preference." />
                </StackPanel>
              </Grid>

              <!-- Failover servers -->
              <StackPanel Spacing="3" Margin="0,6,0,0">
                <TextBlock Text="Failover servers (optional)"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                           Text="If the primary server is unreachable for 3+ minutes, APRS Command tries these in order. One server per line, format: host:port" />
                <TextBox Text="{Binding SelectedPort.AprsIsFailoverServers}"
                         AcceptsReturn="True" Height="72"
                         Watermark="noam.aprs2.net:14580&#x0a;euro.aprs2.net:14580" />
              </StackPanel>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- RepeaterBook API Token -->
    <Border Grid.Row="2"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1" CornerRadius="6" Padding="14,12"
            Background="{DynamicResource AppBgAltBrush}">
      <StackPanel Spacing="8">
        <StackPanel Spacing="2">
          <TextBlock Text="RepeaterBook API Token" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock TextWrapping="Wrap" FontSize="11"
                     Foreground="{DynamicResource TextMutedBrush}"
                     Text="Required for the Club / Net Directory panel. Request a free token at repeaterbook.com/api/token_request.php — approval typically takes a few days. Leave blank until your token is approved." />
        </StackPanel>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
          <TextBox Text="{Binding RepeaterBookApiToken}"
                   Watermark="Paste your approved RepeaterBook API token here"
                   PasswordChar="•"
                   ToolTip.Tip="Your approved RepeaterBook API token. Stored locally on your machine only — never transmitted anywhere except to repeaterbook.com when you use the directory panel." />
          <StackPanel Grid.Column="1" Spacing="4" Orientation="Horizontal">
            <NumericUpDown Value="{Binding RepeaterBookRadiusMiles}"
                           Minimum="5" Maximum="250" Width="90"
                           ToolTip.Tip="Default search radius in miles for the repeater directory." />
            <TextBlock Text="mi" VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Grid>
        <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                   Text="Search radius (miles) — how far from your station to search for repeaters." />
      </StackPanel>
    </Border>

    <!-- Footer: save / revert + status -->
    <Grid Grid.Row="3"
          ColumnDefinitions="Auto,Auto,*"
          ColumnSpacing="8">
      <Button Command="{Binding SaveCommand}"
              Padding="14,6"
              Content="Save" />
      <Button Grid.Column="1"
              Command="{Binding RevertCommand}"
              Padding="10,6"
              Content="Revert" />
      <TextBlock Grid.Column="2"
                 Text="{Binding StatusText}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap" />
    </Grid>
  </Grid>
</UserControl>

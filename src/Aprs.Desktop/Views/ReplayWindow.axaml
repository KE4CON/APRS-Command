<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Aprs.Desktop.Views"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.ReplayWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APRS Command — Replay"
        Width="800" Height="580" MinWidth="600" MinHeight="440">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1" Padding="16,10">
      <StackPanel Spacing="2">
        <TextBlock Text="Replay" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
        <TextBlock Text="Replay a saved packet log as if it were live traffic — no transmitting occurs. To create a file to replay: open Raw Packet Monitor, let it collect packets, then click Save Log. To replay: click Load, select the saved file, then click Play. Use Pause and Stop to control playback. Loop replays the file continuously." Foreground="#526173" FontSize="12" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
    <Border Grid.Row="1" Padding="16">
    <views:ReplayView Grid.Row="1" DataContext="{Binding Replay}" />
    </Border>
    <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,1,0,0" Padding="12">
      <Button Content="Close" HorizontalAlignment="Right" Padding="14,6" Click="Close_Click" />
    </Border>
  </Grid>
</Window>

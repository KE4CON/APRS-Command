<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Aprs.Desktop.Views.SetupWindow"
        Title="APRS Command — First-Run Setup"
        Width="460"
        Height="470"
        CanResize="False"
        WindowStartupLocation="CenterScreen">
  <Border Background="{DynamicResource SurfaceBgBrush}"
          Padding="24">
    <StackPanel Spacing="14">
      <TextBlock Text="Welcome to APRS Command"
                 FontSize="22"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Text="Enter your station details to get started. You can change these later by editing your station profile."
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 TextWrapping="Wrap" />

      <StackPanel Spacing="4">
        <TextBlock Text="Callsign"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBox x:Name="CallsignBox"
                 Watermark="e.g. KE4CON" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Latitude (decimal degrees)"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBox x:Name="LatitudeBox"
                 Watermark="e.g. 42.328068" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Longitude (decimal degrees)"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBox x:Name="LongitudeBox"
                 Watermark="e.g. -88.454975" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Distance units"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <StackPanel Orientation="Horizontal" Spacing="20">
          <RadioButton x:Name="MilesRadio" Content="Miles (US / UK)" IsChecked="True" />
          <RadioButton x:Name="KmRadio" Content="Kilometres (metric)" />
        </StackPanel>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock x:Name="RadiusLabel"
                   Text="Receive filter radius (miles)"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBox x:Name="RadiusBox"
                 Text="125" />
      </StackPanel>

      <TextBlock x:Name="ErrorText"
                 Foreground="{DynamicResource ErrorTextBrush}"
                 IsVisible="False"
                 TextWrapping="Wrap" />

      <Button x:Name="SaveButton"
              Content="Save and continue"
              Click="OnSaveClick"
              HorizontalAlignment="Right"
              Padding="16,8"
              Background="{DynamicResource AccentBlueMidBrush}"
              Foreground="{DynamicResource SurfaceBgBrush}" />
    </StackPanel>
  </Border>
</Window>

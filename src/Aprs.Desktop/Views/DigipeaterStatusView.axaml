<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.DigipeaterStatusView"
             x:DataType="vm:DigipeaterStatusViewModel">
  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="10">
    <StackPanel Spacing="2">
      <TextBlock Text="Digipeater Safety"
                 FontSize="18"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock Text="RF digipeating remains disabled unless digipeater mode, RF transmit, path matching, and port safety all pass."
                 Foreground="{DynamicResource TextSubtleBrush}"
                 FontSize="12"
                 TextWrapping="Wrap" />
    </StackPanel>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*,*,*"
          RowDefinitions="Auto,Auto,Auto"
          ColumnSpacing="10"
          RowSpacing="8">
      <Border BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Background="{DynamicResource SurfaceBgBrush}"
              Padding="10">
        <StackPanel>
          <TextBlock Text="Digipeater"
                     FontSize="11"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <TextBlock Text="{Binding DigipeaterEnabled}"
                     FontWeight="SemiBold" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Background="{DynamicResource SurfaceBgBrush}"
              Padding="10">
        <StackPanel>
          <TextBlock Text="RF transmit"
                     FontSize="11"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <TextBlock Text="{Binding RfTransmitEnabled}"
                     FontWeight="SemiBold" />
        </StackPanel>
      </Border>

      <Border Grid.Column="2"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Background="{DynamicResource SurfaceBgBrush}"
              Padding="10">
        <StackPanel>
          <TextBlock Text="TX port"
                     FontSize="11"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <TextBlock Text="{Binding RfTransmitPort}"
                     FontWeight="SemiBold" />
        </StackPanel>
      </Border>

      <Border Grid.Column="3"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Background="{DynamicResource SurfaceBgBrush}"
              Padding="10">
        <StackPanel>
          <TextBlock Text="Callsign"
                     FontSize="11"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <TextBlock Text="{Binding DigipeaterCallsign}"
                     FontWeight="SemiBold" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Grid.ColumnSpan="4"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Background="{DynamicResource SurfaceBgBrush}"
              Padding="10">
        <Grid ColumnDefinitions="*,*"
              RowDefinitions="Auto,Auto,Auto"
              ColumnSpacing="10"
              RowSpacing="6">
          <StackPanel>
            <TextBlock Text="Aliases"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding SupportedAliases}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="Modes"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding FillInMode, StringFormat='Fill-in: {0}'}" />
            <TextBlock Text="{Binding FullMode, StringFormat='Full: {0}'}" />
          </StackPanel>
          <StackPanel Grid.Row="1">
            <TextBlock Text="Decisions"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding DecisionSummary}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Row="1"
                      Grid.Column="1">
            <TextBlock Text="Validation"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding ErrorSummary}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Row="2">
            <TextBlock Text="Last digipeated packet"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding LastDigipeatedPacket}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Row="2"
                      Grid.Column="1">
            <TextBlock Text="Last blocked reason"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBlock Text="{Binding LastBlockedReason}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Grid>
      </Border>

      <TextBlock Grid.Row="2"
                 Grid.ColumnSpan="4"
                 Text="{Binding LastDecisionTime, StringFormat='Last decision: {0}'}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 FontSize="12" />
    </Grid>

    <ScrollViewer Grid.Row="2">
      <ItemsControl ItemsSource="{Binding Decisions}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="{DynamicResource SurfaceBgBrush}"
                    Padding="10"
                    Margin="0,0,0,8">
              <Grid ColumnDefinitions="Auto,*,*,*,Auto"
                    RowDefinitions="Auto,Auto,Auto"
                    ColumnSpacing="10"
                    RowSpacing="6">
                <TextBlock Text="{Binding Time}"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <StackPanel Grid.Column="1">
                  <TextBlock Text="{Binding Callsign}"
                             FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Source}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Text="{Binding PacketType}" />
                  <TextBlock Text="{Binding TransmitPort}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
                <TextBlock Grid.Column="3"
                           Text="{Binding Decision}"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="4"
                           Text="{Binding TransmitAttempted}" />
                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="5"
                           Text="{Binding Path}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="2"
                           Grid.ColumnSpan="5"
                           Text="{Binding Reason}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Aprs.Desktop.Views"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.RfDiagnosticsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APRS Command — RF Diagnostics"
        Width="900" Height="640" MinWidth="600" MinHeight="440">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1" Padding="16,10">
      <StackPanel Spacing="2">
        <TextBlock Text="RF Diagnostics" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
        <TextBlock Text="Low-level TNC and modem diagnostics — frame counts, decode errors, station rates, and path warnings. Use when something on the radio side isn't working right." Foreground="#526173" FontSize="12" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
    <views:RfDiagnosticsView Grid.Row="1" DataContext="{Binding RfDiagnostics}" />
    <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,1,0,0" Padding="12">
      <Button Content="Close" HorizontalAlignment="Right" Padding="14,6" Click="Close_Click" />
    </Border>
  </Grid>
</Window>

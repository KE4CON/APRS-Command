<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Aprs.Desktop.Views"
             x:Class="Aprs.Desktop.Views.SettingsView">
  <Grid RowDefinitions="Auto,*"
        Margin="0,10,0,0">
    <StackPanel Grid.Row="0"
                Margin="0,0,0,12">
      <TextBlock Text="Settings"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <TextBlock Text="Connection and safety settings"
                 Foreground="{DynamicResource TextSubtleBrush}" />
    </StackPanel>
    <TabControl Grid.Row="1">
      <TabItem Header="Readiness">
        <Border BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource CardBgBrush}">
          <views:ReadinessView DataContext="{Binding Readiness}" />
        </Border>
      </TabItem>
      <TabItem Header="First Run">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <views:FirstRunSetupView DataContext="{Binding FirstRunSetup}" />
        </Border>
      </TabItem>
      <TabItem Header="Station">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <views:StationSetupView DataContext="{Binding StationSetup}" />
        </Border>
      </TabItem>
      <TabItem Header="GPS">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <TabControl>
            <TabItem Header="Setup">
              <views:GpsConfigView DataContext="{Binding GpsConfig}" />
            </TabItem>
            <TabItem Header="Status">
              <views:GpsStatusView DataContext="{Binding GpsStatus}" />
            </TabItem>
          </TabControl>
        </Border>
      </TabItem>
      <TabItem Header="Offline Maps">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <views:OfflineMapManagerView />
        </Border>
      </TabItem>
      <TabItem Header="Connections">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <views:ConnectionsView DataContext="{Binding Connections}" />
        </Border>
      </TabItem>
      <TabItem Header="Managed Modem">
        <Border BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource CardBgBrush}">
          <views:ManagedModemView DataContext="{Binding ManagedModem}" />
        </Border>
      </TabItem>
      <TabItem Header="Message Templates">
        <Border BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="0"
                Background="{DynamicResource CardBgBrush}">
          <views:MessageTemplatesView DataContext="{Binding MessageTemplates}" />
        </Border>
      </TabItem>
      <TabItem Header="Smart Beaconing">
        <Border BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="0"
                Background="{DynamicResource CardBgBrush}">
          <views:SmartBeaconingView DataContext="{Binding SmartBeaconing}" />
        </Border>
      </TabItem>
      <TabItem Header="Ports">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <views:PortStatusView DataContext="{Binding PortStatus}" />
        </Border>
      </TabItem>
      <TabItem Header="iGate">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <TabControl>
            <TabItem Header="Setup">
              <views:IGateConfigView DataContext="{Binding IGateConfig}" />
            </TabItem>
            <TabItem Header="Status">
              <views:IGateStatusView DataContext="{Binding IGateStatus}" />
            </TabItem>
          </TabControl>
        </Border>
      </TabItem>
      <TabItem Header="Digipeater">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <TabControl>
            <TabItem Header="Setup">
              <views:DigipeaterConfigView DataContext="{Binding DigipeaterConfig}" />
            </TabItem>
            <TabItem Header="Status">
              <views:DigipeaterStatusView DataContext="{Binding DigipeaterStatus}" />
            </TabItem>
          </TabControl>
        </Border>
      </TabItem>
      <TabItem Header="Audio">
        <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="{DynamicResource TextTitleBarBrush}">
          <views:AudioConfigView DataContext="{Binding AudioConfig}" />
        </Border>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>

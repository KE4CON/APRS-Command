<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:Aprs.Desktop.Views"
             x:Class="Aprs.Desktop.Views.SettingsView">
  <Grid RowDefinitions="Auto,*"
        Margin="0,10,0,0">
    <StackPanel Grid.Row="0"
                Margin="0,0,0,12">
      <TextBlock Text="Settings"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <TextBlock Text="Connection and safety settings"
                 Foreground="#526173" />
    </StackPanel>
    <TabControl Grid.Row="1">
      <TabItem Header="First Run">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:FirstRunSetupView DataContext="{Binding FirstRunSetup}" />
        </Border>
      </TabItem>
      <TabItem Header="Station">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:StationSetupView DataContext="{Binding StationSetup}" />
        </Border>
      </TabItem>
      <TabItem Header="GPS">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:GpsStatusView DataContext="{Binding GpsStatus}" />
        </Border>
      </TabItem>
      <TabItem Header="Offline Maps">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:OfflineMapManagerView />
        </Border>
      </TabItem>
      <TabItem Header="Connections">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:ConnectionsView DataContext="{Binding Connections}" />
        </Border>
      </TabItem>
      <TabItem Header="Ports">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <views:PortStatusView DataContext="{Binding PortStatus}" />
        </Border>
      </TabItem>
      <TabItem Header="iGate">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <TabControl>
            <TabItem Header="Setup">
              <views:IGateConfigView DataContext="{Binding IGateConfig}" />
            </TabItem>
            <TabItem Header="Status">
              <views:IGateStatusView DataContext="{Binding IGateStatus}" />
            </TabItem>
          </TabControl>
        </Border>
      </TabItem>
      <TabItem Header="Digipeater">
        <Border BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Background="#F8FAFC">
          <TabControl>
            <TabItem Header="Setup">
              <views:DigipeaterConfigView DataContext="{Binding DigipeaterConfig}" />
            </TabItem>
            <TabItem Header="Status">
              <views:DigipeaterStatusView DataContext="{Binding DigipeaterStatus}" />
            </TabItem>
          </TabControl>
        </Border>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>

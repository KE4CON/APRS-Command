<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.MessageReceiptsDashboardWindow"
        x:DataType="vm:MessageReceiptsDashboardViewModel"
        Title="Message Read Receipts Dashboard"
        Width="720" Height="560"
        MinWidth="600" MinHeight="440"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource AppBgBrush}">

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}" Padding="16,12">
      <StackPanel Spacing="2">
        <TextBlock Text="Message Read Receipts Dashboard" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextTitleBarBrush}" />
        <TextBlock FontSize="10" Foreground="{DynamicResource TextSidebarBrush}"
                   Text="Overview of message delivery status across the session." />
      </StackPanel>
    </Border>

    <!-- Summary cards -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8" Margin="14,10">
      <Border Background="{DynamicResource AppBgAltBrush}" CornerRadius="5" Padding="10,8">
        <StackPanel Spacing="2" HorizontalAlignment="Center">
          <TextBlock Text="{Binding TotalCount}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Total" FontSize="9" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Background="{DynamicResource AppBgAltBrush}" CornerRadius="5" Padding="10,8">
        <StackPanel Spacing="2" HorizontalAlignment="Center">
          <TextBlock Text="{Binding AcknowledgedCount}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                     Foreground="#15803d" />
          <TextBlock Text="Acknowledged" FontSize="9" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Background="{DynamicResource AppBgAltBrush}" CornerRadius="5" Padding="10,8">
        <StackPanel Spacing="2" HorizontalAlignment="Center">
          <TextBlock Text="{Binding WaitingCount}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                     Foreground="#1d4ed8" />
          <TextBlock Text="Waiting" FontSize="9" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Background="{DynamicResource AppBgAltBrush}" CornerRadius="5" Padding="10,8">
        <StackPanel Spacing="2" HorizontalAlignment="Center">
          <TextBlock Text="{Binding PendingCount}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                     Foreground="#6b7280" />
          <TextBlock Text="Pending" FontSize="9" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="4" Background="{DynamicResource AppBgAltBrush}" CornerRadius="5" Padding="10,8">
        <StackPanel Spacing="2" HorizontalAlignment="Center">
          <TextBlock Text="{Binding FailedCount}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                     Foreground="#dc2626" />
          <TextBlock Text="Failed" FontSize="9" HorizontalAlignment="Center"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Message list -->
    <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="14,0,14,10">
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
        <TextBlock Text="Messages" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
        <ComboBox Grid.Column="1" ItemsSource="{Binding StatusFilterOptions}"
                  SelectedItem="{Binding StatusFilter}" FontSize="10" Width="150" />
      </Grid>
      <ListBox Grid.Row="1" ItemsSource="{Binding Messages}"
               Background="{DynamicResource AppBgAltBrush}">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ReceiptRowViewModel">
            <Grid ColumnDefinitions="34,30,80,80,*,110" Margin="4,3">
              <TextBlock Text="{Binding StatusIcon}" FontSize="13" FontWeight="Bold"
                         Foreground="{Binding StatusColor}" VerticalAlignment="Center"
                         HorizontalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding Direction}" FontSize="9"
                         Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding Sender}" FontSize="10" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBlueMidBrush}" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Column="3" Text="{Binding Recipient}" FontSize="10"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Column="4" Text="{Binding Body}" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
              <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                <TextBlock Text="{Binding StatusLabel}" FontSize="9" FontWeight="SemiBold"
                           Foreground="{Binding StatusColor}" VerticalAlignment="Center" />
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>

    <!-- Footer -->
    <Border Grid.Row="3" Padding="12,8" Background="{DynamicResource AppBgAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBlock Text="{Binding StatusText}" FontSize="10"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                Content="↻ Refresh" Padding="10,5" FontSize="10" />
        <Button Grid.Column="2" x:Name="CloseButton" Content="Close" Padding="12,5" />
      </Grid>
    </Border>
  </Grid>
</Window>

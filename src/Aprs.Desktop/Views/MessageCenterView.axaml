<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.MessageCenterView"
             x:DataType="vm:MessageCenterViewModel">
  <Grid RowDefinitions="Auto,*"
        Margin="0,10,0,0">
    <StackPanel Grid.Row="0"
                Margin="0,0,0,12">
      <TextBlock Text="Messages"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <TextBlock Text="Inbox, outbox, drafts, and compose staging"
                 Foreground="{DynamicResource TextSubtleBrush}" />
    </StackPanel>

    <Grid Grid.Row="1"
          RowDefinitions="*,Auto"
          RowSpacing="10">
      <TabControl>
        <TabItem Header="Inbox">
          <ListBox ItemsSource="{Binding Inbox}"
                   SelectedItem="{Binding SelectedMessage}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:MessageRowViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      Margin="0,3">
                  <TextBlock Text="{Binding RemoteStation}"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Body}"
                             TextTrimming="CharacterEllipsis"
                             Foreground="{DynamicResource TitleBarBorderBrush}" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding Timestamp}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Bulletins">
          <ListBox ItemsSource="{Binding Bulletins}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:BulletinRowViewModel">
                <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,3">
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                        ColumnSpacing="8">
                    <TextBlock Text="{Binding Sender}"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding BulletinId}"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Text}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Status}"
                               Foreground="{DynamicResource TextMutedBrush}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Announcements">
          <ListBox ItemsSource="{Binding Announcements}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:AnnouncementRowViewModel">
                <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,3">
                  <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                        ColumnSpacing="8">
                    <TextBlock Text="{Binding Sender}"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding AnnouncementId}"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Text}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Source}"
                               Foreground="{DynamicResource TextMutedBrush}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Queries">
          <ListBox ItemsSource="{Binding Queries}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:QueryRowViewModel">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                      ColumnSpacing="8"
                      Margin="0,3">
                  <TextBlock Text="{Binding Sender}"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding QueryType}"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding QueryBody}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="3"
                             Text="{Binding Received}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Outbox">
          <ListBox ItemsSource="{Binding Outbox}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:MessageRowViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      Margin="0,3">
                  <TextBlock Text="{Binding RemoteStation}"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Body}"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding Status}"
                             Foreground="{DynamicResource TextMutedBrush}" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Drafts">
          <ListBox ItemsSource="{Binding Drafts}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:MessageRowViewModel">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="8"
                      Margin="0,3">
                  <TextBlock Text="{Binding RemoteStation}"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Body}"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
        <TabItem Header="Thread">
          <ListBox ItemsSource="{Binding Conversation}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:MessageRowViewModel">
                <Border BorderBrush="{DynamicResource TextSidebarBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8"
                        Margin="0,3">
                  <StackPanel Spacing="3">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{Binding Direction}"
                                 FontWeight="SemiBold" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Status}"
                                 Foreground="{DynamicResource TextMutedBrush}" />
                    </Grid>
                    <TextBlock Text="{Binding Body}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ValidationSummary}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </TabItem>
      </TabControl>

      <Border Grid.Row="1"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Background="{DynamicResource TextTitleBarBrush}"
              Padding="10">
        <Grid ColumnDefinitions="*,*,2*"
              RowDefinitions="Auto,Auto,Auto"
              ColumnSpacing="8"
              RowSpacing="6">
          <!-- Template picker -->
          <StackPanel Grid.ColumnSpan="3" Spacing="2" Margin="0,0,0,2">
            <TextBlock Text="Template (optional)"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <ComboBox x:Name="TemplateCombo"
                      ItemsSource="{Binding Templates.Templates}"
                      PlaceholderText="Pick a template to pre-fill compose…"
                      HorizontalAlignment="Stretch"
                      SelectionChanged="TemplateCombo_SelectionChanged">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" />
                    <TextBlock Text="{Binding Body}" FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextTrimming="CharacterEllipsis" MaxWidth="280" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
          <StackPanel Grid.Row="1">
            <TextBlock Text="From"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBox Text="{Binding ComposeLocalStation}" />
          </StackPanel>
          <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="To"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBox Text="{Binding ComposeRecipient}" />
          </StackPanel>
          <StackPanel Grid.Row="1" Grid.Column="2">
            <TextBlock Text="Message"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <TextBox Text="{Binding ComposeBody}" />
          </StackPanel>
          <TextBlock Grid.Row="2"
                     Grid.ColumnSpan="3"
                     Text="{Binding ComposeValidationSummary}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="11" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Aprs.Desktop.Views"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.MessagesWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APRS Command — Messages"
        Width="900" Height="680" MinWidth="700" MinHeight="500">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1" Padding="16,10">
      <StackPanel Spacing="2">
        <TextBlock Text="Messages" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
        <TextBlock Text="Direct messages, bulletins, announcements and queries. Inbox shows messages addressed to your callsign. Use the Compose tab to send a direct message — your callsign is filled in automatically from Station Setup." Foreground="#526173" FontSize="12" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
    <Border Grid.Row="1" Padding="16">
    <views:MessageCenterView Grid.Row="1" DataContext="{Binding MessageCenter}" />
    </Border>
    <Border Grid.Row="2" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="0,1,0,0" Padding="12">
      <Button Content="Close" HorizontalAlignment="Right" Padding="14,6" Click="Close_Click" />
    </Border>
  </Grid>
</Window>

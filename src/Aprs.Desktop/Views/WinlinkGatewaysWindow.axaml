<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.WinlinkGatewaysWindow"
        x:DataType="vm:WinlinkGatewaysViewModel"
        Title="Winlink RMS Gateways"
        Width="600" Height="480"
        MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource AppBgBrush}">

    <!-- Header / API key setup -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}" Padding="16,12">
      <StackPanel Spacing="10">
        <StackPanel Spacing="2">
          <TextBlock Text="Winlink RMS Gateways" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextTitleBarBrush}" />
          <TextBlock FontSize="10" Foreground="{DynamicResource TextSidebarBrush}" TextWrapping="Wrap"
                     Text="Find nearby Winlink RMS gateway stations. Requires a Winlink API access key — request one from a Winlink administrator at api.winlink.org (free, but not self-service)." />
        </StackPanel>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="Winlink API key" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
            <TextBox Text="{Binding ApiKeyInput}" Watermark="Paste your API key here…"
                     PasswordChar="•" />
          </StackPanel>
          <Button Grid.Column="1" Command="{Binding SaveKeyCommand}"
                  Content="Save key" Padding="10,5" FontSize="10"
                  VerticalAlignment="Bottom" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Gateway list -->
    <Grid Grid.Row="1" RowDefinitions="Auto,*">
      <Border Grid.Row="0" Padding="14,8">
        <TextBlock Text="Nearby gateways" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Gateways}"
               Background="{DynamicResource AppBgBrush}">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:WinlinkGatewayRowViewModel">
            <Grid ColumnDefinitions="100,90,60,*" Margin="4,3">
              <TextBlock Text="{Binding Callsign}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBlueMidBrush}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding Frequency}" FontSize="10"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding Mode}" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="3" Text="{Binding Position}" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>

    <!-- Footer -->
    <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource AppBgAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBlock Text="{Binding StatusText}" FontSize="10"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                   TextWrapping="Wrap" />
        <Button Grid.Column="1" Command="{Binding QueryCommand}"
                Content="🔍 Query nearby gateways" Padding="10,5" FontSize="10"
                IsEnabled="{Binding IsNotQuerying}" />
        <Button Grid.Column="2" x:Name="CloseButton" Content="Close" Padding="12,5" />
      </Grid>
    </Border>
  </Grid>
</Window>

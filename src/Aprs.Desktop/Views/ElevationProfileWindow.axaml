<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.ElevationProfileWindow"
        x:DataType="vm:ElevationProfileViewModel"
        Title="Elevation Profile"
        Width="680" Height="520"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource AppBgBrush}">

    <!-- Input -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}" Padding="16,12">
      <StackPanel Spacing="10">
        <TextBlock Text="Elevation Profile" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextTitleBarBrush}" />
        <Grid ColumnDefinitions="*,Auto,*,Auto" ColumnSpacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="From callsign" FontSize="10" Foreground="{DynamicResource TextSidebarBrush}" />
            <TextBox Text="{Binding FromCallsign}" Watermark="e.g. KE4CON" />
          </StackPanel>
          <TextBlock Grid.Column="1" Text="→" FontSize="18" VerticalAlignment="Center"
                     Foreground="{DynamicResource TextSidebarBrush}" Margin="0,12,0,0" />
          <StackPanel Grid.Column="2" Spacing="2">
            <TextBlock Text="To callsign" FontSize="10" Foreground="{DynamicResource TextSidebarBrush}" />
            <TextBox Text="{Binding ToCallsign}" Watermark="e.g. W4ABC" />
          </StackPanel>
          <Button Grid.Column="3" Command="{Binding GenerateCommand}"
                  Content="Generate Profile" Padding="14,6"
                  IsEnabled="{Binding IsNotLoading}"
                  VerticalAlignment="Bottom" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Profile chart -->
    <ScrollViewer Grid.Row="1" Padding="16,12">
      <StackPanel Spacing="8">
        <ProgressBar IsVisible="{Binding IsLoading}" IsIndeterminate="True" Height="4" />
        <TextBlock IsVisible="{Binding IsLoading}"
                   Text="Fetching elevation data from Open Elevation API…"
                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                   HorizontalAlignment="Center" />
        <TextBox Text="{Binding ProfileText}"
                 IsReadOnly="True"
                 FontFamily="Courier New, Cascadia Code, Menlo, Monaco, monospace"
                 FontSize="11"
                 Background="{DynamicResource AppBgAltBrush}"
                 BorderThickness="1"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 IsVisible="{Binding IsNotLoading}" />
      </StackPanel>
    </ScrollViewer>

    <!-- Footer -->
    <Border Grid.Row="2" Padding="14,8" Background="{DynamicResource AppBgAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <TextBlock Text="{Binding StatusText}" FontSize="10"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"
                   TextWrapping="Wrap" />
        <Button Grid.Column="1" x:Name="CloseButton" Content="Close" Padding="12,6" />
      </Grid>
    </Border>
  </Grid>
</Window>

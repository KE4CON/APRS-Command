<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Aprs.Desktop.Views"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.RawPacketsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APRS Command — Raw Packet Monitor"
        Width="900" Height="600" MinWidth="600" MinHeight="440">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Background="{DynamicResource AppBgAltBrush}" BorderBrush="{DynamicResource TextSidebarBrush}" BorderThickness="0,0,0,1" Padding="22,10">
      <StackPanel Spacing="2">
        <TextBlock Text="Raw Packet Monitor" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Text="Every packet received on all active ports, in arrival order. Use this to confirm your connection is working — if packets appear here, the port is receiving. Use the Clear button to reset the log. To save the log for Replay, click Save Log and choose a location; that file can then be loaded in the Replay window." Foreground="{DynamicResource TextSubtleBrush}" FontSize="12" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
    <Border Grid.Row="1" Padding="16">
    <views:PacketMonitorView Grid.Row="1" DataContext="{Binding RawPacketLog}" />
    </Border>
    <Border Grid.Row="2" Background="{DynamicResource AppBgAltBrush}" BorderBrush="{DynamicResource TextSidebarBrush}" BorderThickness="0,1,0,0" Padding="12">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <Button Content="Save Log"
                Padding="14,6"
                ToolTip.Tip="Save all received packets to a file that can be loaded in the Replay window"
                Click="SaveLog_Click" />
        <TextBlock Grid.Column="1"
                   Text="Tip: save the log here, then open Replay to play it back without transmitting."
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="11"
                   VerticalAlignment="Center"
                   Margin="12,0" />
        <Button Grid.Column="2" Content="Close" Padding="14,6" Click="Close_Click" />
      </Grid>
    </Border>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        xmlns:views="using:Aprs.Desktop.Views"
        x:Class="Aprs.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APRS Command"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="620">

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Title bar -->
    <Border Grid.Row="0"
            Background="#18212B"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="10">
        <StackPanel Spacing="1">
          <TextBlock Text="APRS Command"
                     FontSize="19"
                     FontWeight="SemiBold"
                     Foreground="#F8FAFC" />
          <TextBlock Text="APRS station map"
                     FontSize="12"
                     Foreground="#CBD5E1" />
        </StackPanel>
        <Border Grid.Column="1"
                x:Name="AprsIsBadgeBorder"
                Background="#1E293B"
                BorderBrush="#64748B"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock x:Name="AprsIsBadgeText"
                     Text="APRS-IS Offline"
                     Foreground="#E2E8F0"
                     FontWeight="SemiBold" />
        </Border>
        <Border Grid.Column="2"
                x:Name="TxBadgeBorder"
                Background="#123B32"
                BorderBrush="#2DD4BF"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock x:Name="TxBadgeText"
                     Text="TX Disabled"
                     Foreground="#D9FFF7"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <!-- Menu bar -->
    <Menu Grid.Row="1"
          Background="#F1F5F9">
      <MenuItem Header="_Settings" Command="{Binding OpenSettingsCommand}" />
      <MenuItem Header="_Messages" Command="{Binding OpenMessagesCommand}" />
      <MenuItem Header="_Objects" Command="{Binding OpenObjectsCommand}" />
      <MenuItem Header="_Events" Command="{Binding OpenEventsCommand}" />
      <MenuItem Header="_Weather" Command="{Binding OpenWeatherCommand}" />
      <MenuItem Header="Station _List" Command="{Binding OpenStationListCommand}" />
      <MenuItem Header="Raw _Packets" Command="{Binding OpenRawPacketsCommand}" />
      <MenuItem Header="_Alerts" Command="{Binding OpenAlertsCommand}" />
      <MenuItem Header="_Tools">
        <MenuItem Header="Event Bus" Command="{Binding OpenEventBusCommand}" />
        <MenuItem Header="Replay" Command="{Binding OpenReplayCommand}" />
        <MenuItem Header="RF Diagnostics" Command="{Binding OpenRfDiagnosticsCommand}" />
        <Separator />
        <MenuItem Header="Toggle Exercise Mode (inhibit all transmit)"
                  Command="{Binding ToggleExerciseModeCommand}" />
      </MenuItem>
      <MenuItem Header="_Help" Command="{Binding OpenHelpCommand}" />
      <MenuItem Header="About APRS Command" Command="{Binding OpenAboutCommand}" />
    </Menu>

    <!-- Main content: icon sidebar + map -->
    <Grid Grid.Row="2"
          ColumnDefinitions="56,*">

      <!-- Left icon sidebar -->
      <Border Grid.Column="0"
              Background="#1E293B"
              BorderBrush="#334155"
              BorderThickness="0,0,1,0">
        <StackPanel VerticalAlignment="Top"
                    Spacing="4"
                    Margin="4,12">

          <!-- Map tools -->
          <Button ToolTip.Tip="Home / Reset view"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,10"
                  Background="Transparent"
                  Foreground="#CBD5E1"
                  FontSize="24"
                  Command="{Binding Map.HomeCommand}">
            <TextBlock Text="⌂" />
          </Button>
          <Button ToolTip.Tip="Centre on my station"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,10"
                  Background="Transparent"
                  Foreground="#CBD5E1"
                  FontSize="24"
                  Command="{Binding Map.CentreOnStationCommand}">
            <TextBlock Text="◎" />
          </Button>
          <Button ToolTip.Tip="Find station"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,10"
                  Background="Transparent"
                  Foreground="#CBD5E1"
                  FontSize="24">
            <TextBlock Text="🔍" />
          </Button>
          <Button ToolTip.Tip="Measure distance"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,10"
                  Background="Transparent"
                  Foreground="#CBD5E1"
                  FontSize="24">
            <TextBlock Text="📏" />
          </Button>
          <Button ToolTip.Tip="Map layer toggle"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,10"
                  Background="Transparent"
                  Foreground="#CBD5E1"
                  FontSize="24">
            <TextBlock Text="🗺" />
          </Button>

          <!-- Divider -->
          <Border Height="1"
                  Background="#334155"
                  Margin="4,8" />

          <!-- Operator tools -->
          <Button ToolTip.Tip="Beacon Now — transmit your position"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,10"
                  Background="Transparent"
                  Foreground="#CBD5E1"
                  FontSize="24"
                  Command="{Binding BeaconNowCommand}">
            <TextBlock Text="📡" />
          </Button>
          <Button ToolTip.Tip="Alert status"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,10"
                  Background="Transparent"
                  Foreground="#CBD5E1"
                  FontSize="24">
            <TextBlock Text="🔔" />
          </Button>
        </StackPanel>
      </Border>

      <!-- Map fills everything -->
      <views:MapView Grid.Column="1"
                     DataContext="{Binding Map}" />
    </Grid>

    <views:MainStatusBarView Grid.Row="3" />
  </Grid>
</Window>

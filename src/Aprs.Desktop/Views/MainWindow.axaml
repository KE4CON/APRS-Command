<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        xmlns:views="using:Aprs.Desktop.Views"
        x:Class="Aprs.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APRS Command"
        Width="1200"
        Height="760"
        MinWidth="900"
        MinHeight="620">

  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

    <!-- Title bar -->
    <Border Grid.Row="0"
            Background="{DynamicResource TitleBarBgBrush}"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="10">
        <StackPanel Spacing="1">
          <TextBlock Text="APRS Command"
                     FontSize="19"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextTitleBarBrush}" />
          <TextBlock Text="APRS station map"
                     FontSize="12"
                     Foreground="{DynamicResource TextSidebarBrush}" />
        </StackPanel>
        <Border Grid.Column="1"
                x:Name="AprsIsBadgeBorder"
                Background="{DynamicResource AppBgAltBrush}"
                BorderBrush="{DynamicResource TextMutedBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock x:Name="AprsIsBadgeText"
                     Text="APRS-IS Offline"
                     Foreground="{DynamicResource TextOnDarkBrush}"
                     FontWeight="SemiBold" />
        </Border>
        <Border Grid.Column="2"
                x:Name="TxBadgeBorder"
                Background="{DynamicResource AccentTealBgBrush}"
                BorderBrush="{DynamicResource AccentTealBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6"
                VerticalAlignment="Center">
          <TextBlock x:Name="TxBadgeText"
                     Text="TX Disabled"
                     Foreground="{DynamicResource AccentTealTextBrush}"
                     FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <!-- Menu bar -->
    <Menu Grid.Row="1"
          Background="{DynamicResource AppBgAltBrush}">
      <MenuItem Header="_Settings" Command="{Binding OpenSettingsCommand}" />
      <MenuItem Header="_Messages" Command="{Binding OpenMessagesCommand}" />
      <MenuItem Header="_Net Control" Command="{Binding OpenNetControlCommand}" />
      <MenuItem Header="_Objects" Command="{Binding OpenObjectsCommand}" />
      <MenuItem Header="_Events" Command="{Binding OpenEventsCommand}" />
      <MenuItem Header="_Draw">
        <MenuItem Header="✏ Draw Line"    Command="{Binding Map.DrawLineCommand}"    ToolTip.Tip="Click to add points, double-click to finish" />
        <MenuItem Header="⬟ Draw Polygon" Command="{Binding Map.DrawPolygonCommand}" ToolTip.Tip="Click to add points, double-click to close" />
        <MenuItem Header="◯ Draw Circle"  Command="{Binding Map.DrawCircleCommand}"  ToolTip.Tip="Click centre, click again to set radius" />
        <MenuItem Header="✕ Erase Shape"  Command="{Binding Map.DrawEraseCommand}"   ToolTip.Tip="Click a shape to delete it" />
        <Separator />
        <MenuItem Header="Clear All Drawings" Command="{Binding Map.ClearDrawingsCommand}" />
      </MenuItem>
      <MenuItem Header="_Weather">
        <MenuItem Header="Weather Stations" Command="{Binding OpenWeatherCommand}" />
        <MenuItem Header="Weather Alerts" Command="{Binding OpenNwsAlertsCommand}" />
        <Separator />
        <MenuItem x:Name="ToggleRadarMenuItem"
                  Header="{Binding Map.RadarMenuHeaderText}"
                  Click="ToggleRadarMenuItem_Click" />
      </MenuItem>
      <MenuItem Header="Station _List" Command="{Binding OpenStationListCommand}" />
      <MenuItem Header="Raw _Packets" Command="{Binding OpenRawPacketsCommand}" />
      <MenuItem Header="After-Action _Report" Command="{Binding OpenAfterActionCommand}" />
      <MenuItem Header="Offline _Map Download" Command="{Binding OpenOfflineMapCommand}" />
      <MenuItem Header="_Frequency Reference" Command="{Binding OpenFrequencyRefCommand}" />
      <MenuItem Header="_Elevation Profile" Command="{Binding OpenElevationCommand}" />
      <MenuItem Header="_Shadow Beacon" Command="{Binding OpenShadowBeaconCommand}" />
      <MenuItem Header="_Coverage Prediction" Command="{Binding OpenCoverageCommand}" />
      <MenuItem Header="_Net Script Editor" Command="{Binding OpenNetScriptCommand}" />
      <MenuItem Header="_Message Broadcast" Command="{Binding OpenBroadcastCommand}" />
      <MenuItem Header="_Scheduled Messages" Command="{Binding OpenScheduledCommand}" />
      <MenuItem Header="_Message Receipts Dashboard" Command="{Binding OpenReceiptsCommand}" />
      <MenuItem Header="_Packet Statistics Dashboard" Click="OpenPacketStatistics_Click" />
      <MenuItem Header="_Winlink RMS Gateways" Command="{Binding OpenWinlinkCommand}" />
      <MenuItem Header="_Alerts" Command="{Binding OpenAlertsCommand}" />
      <MenuItem Header="_Tools">
        <MenuItem Header="Event Bus" Command="{Binding OpenEventBusCommand}" />
        <MenuItem Header="Replay" Command="{Binding OpenReplayCommand}" />
        <MenuItem Header="RF Diagnostics" Command="{Binding OpenRfDiagnosticsCommand}" />
        <Separator />
        <MenuItem Header="Toggle Exercise Mode (inhibit all transmit)"
                  Command="{Binding ToggleExerciseModeCommand}" />
        <Separator />
        <MenuItem Header="Toggle Dark Mode"
                  Command="{Binding ToggleDarkModeCommand}" />
      </MenuItem>
      <MenuItem Header="_Help" Command="{Binding OpenHelpCommand}" />
      <MenuItem Header="About APRS Command" Command="{Binding OpenAboutCommand}" />
    </Menu>

    <!-- Main content: icon sidebar + map -->
    <Grid Grid.Row="4"
          ColumnDefinitions="56,*">

      <!-- Left icon sidebar -->
      <Border Grid.Column="0"
              Background="{DynamicResource SidebarBgBrush}"
              BorderBrush="{DynamicResource TitleBarBorderBrush}"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto">
          <StackPanel VerticalAlignment="Top"
                    Spacing="4"
                    Margin="4,12">

          <!-- Map tools -->
          <Button ToolTip.Tip="Home / Reset view"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,12"
                  Background="Transparent"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  FontSize="30"
                  Command="{Binding Map.HomeCommand}">
            <TextBlock Text="⌂" />
          </Button>
          <Button ToolTip.Tip="Centre on my station"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,12"
                  Background="Transparent"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  FontSize="30"
                  Command="{Binding Map.CentreOnStationCommand}">
            <TextBlock Text="◎" />
          </Button>
          <Button ToolTip.Tip="Find station"
                  Command="{Binding Map.FindStationCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,12"
                  Background="Transparent"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  FontSize="30">
            <TextBlock Text="🔍" />
          </Button>
          <Button ToolTip.Tip="Measure distance"
                  Command="{Binding Map.MeasureDistanceCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,12"
                  Background="Transparent"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  FontSize="30">
            <TextBlock Text="📏" />
          </Button>
          <Button ToolTip.Tip="Map layer toggle"
                  Command="{Binding Map.ToggleMapLayerCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,12"
                  Background="Transparent"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  FontSize="30">
            <TextBlock Text="🗺" />
          </Button>

          <!-- Divider -->
          <Border Height="1"
                  Background="{DynamicResource TitleBarBorderBrush}"
                  Margin="4,8" />

          <!-- Operator tools -->
          <Button ToolTip.Tip="Beacon Now — transmit your position"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,12"
                  Background="Transparent"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  FontSize="30"
                  Command="{Binding BeaconNowCommand}">
            <TextBlock Text="📡" />
          </Button>
          <Button ToolTip.Tip="Alert status"
                  Command="{Binding Map.AlertStatusCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="4,12"
                  Background="Transparent"
                  Foreground="{DynamicResource TextSidebarBrush}"
                  FontSize="30">
            <TextBlock Text="🔔" />
          </Button>

          <Button ToolTip.Tip="{Binding Map.CustomRingCenterLabel}"
                  Command="{Binding Map.ToggleRingsCommand}"
                  Padding="4,12"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Background="Transparent"
                  BorderThickness="0"
                  FontSize="30"
                  Foreground="{DynamicResource TextSidebarBrush}">
            <TextBlock Text="⊙" />
          </Button>

          <Button ToolTip.Tip="{Binding Map.TrailsButtonTooltip}"
                  Command="{Binding Map.ToggleTrailsCommand}"
                  Padding="4,12"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Background="Transparent"
                  BorderThickness="0"
                  FontSize="30"
                  Foreground="{DynamicResource TextSidebarBrush}">
            <TextBlock Text="🛤" />
          </Button>

          <Button ToolTip.Tip="{Binding Map.RadarButtonTooltip}"
                  Command="{Binding Map.ToggleRadarCommand}"
                  Padding="4,12"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Background="{Binding Map.RadarButtonBackground}"
                  BorderThickness="0"
                  CornerRadius="6"
                  FontSize="30"
                  Foreground="{DynamicResource TextSidebarBrush}">
            <TextBlock Text="🌧" />
          </Button>
        </StackPanel>
        </Grid>
      </Border>

      <!-- Map fills everything -->
      <views:MapView Grid.Column="1"
                     x:Name="TheMapView"
                     DataContext="{Binding Map}" />
    </Grid>

    <!-- NWS weather alert banner — visible only when alerts are active -->
    <views:NwsAlertsBannerView Grid.Row="2"
                               DataContext="{Binding NwsAlerts}"
                               Cursor="Hand"
                               PointerPressed="NwsBanner_PointerPressed" />

    <!-- Draw mode indicator banner — visible when a draw tool is active -->
    <Border Grid.Row="3" IsVisible="{Binding Map.IsDrawModeActive}"
            Background="#1d4ed8" Padding="10,5">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding Map.DrawModeTooltip}" FontSize="11" FontWeight="SemiBold"
                   Foreground="White" VerticalAlignment="Center" />
        <Button Grid.Column="1" Content="✕ Exit" Padding="8,3" FontSize="10"
                Command="{Binding Map.ClearDrawingsCommand}"
                Background="Transparent" Foreground="White"
                BorderThickness="1" BorderBrush="White" />
      </Grid>
    </Border>

    <views:MainStatusBarView Grid.Row="5" />
  </Grid>
</Window>

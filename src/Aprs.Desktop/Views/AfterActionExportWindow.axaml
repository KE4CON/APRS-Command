<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.AfterActionExportWindow"
        x:DataType="vm:AfterActionExportViewModel"
        Title="After-Action Report Export"
        Width="480" Height="460"
        MinWidth="420" MinHeight="400"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource AppBgBrush}">

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}" Padding="16,12">
      <StackPanel Spacing="2">
        <TextBlock Text="After-Action Report Export" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextTitleBarBrush}" />
        <TextBlock FontSize="11" Foreground="{DynamicResource TextSidebarBrush}"
                   Text="Export session data for filing with served agencies or for your records." />
      </StackPanel>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" Padding="20,16">
      <StackPanel Spacing="14">

        <!-- Event name -->
        <StackPanel Spacing="4">
          <TextBlock Text="Event / operation name" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBox Text="{Binding EventName}"
                   Watermark="e.g. Field Day 2026, Hurricane Prep Exercise, Parade Detail…" />
        </StackPanel>

        <!-- Session data summary -->
        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="5" Padding="12" Background="{DynamicResource CardBgBrush}">
          <StackPanel Spacing="6">
            <TextBlock Text="Session data available" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
              <StackPanel Spacing="1">
                <TextBlock Text="{Binding StationCount}" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBlueMidBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Stations heard" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="1">
                <TextBlock Text="{Binding MessageCount}" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBlueMidBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Messages" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="1">
                <TextBlock Text="{Binding PacketCount}" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBlueMidBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Packets logged" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Export options -->
        <StackPanel Spacing="4">
          <TextBlock Text="Include in export" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <CheckBox IsChecked="{Binding IncludeTextSummary}"
                    Content="Text summary (AAR_…_Summary.txt)"
                    ToolTip.Tip="A formatted plain-text report showing stations heard, messages, and packet statistics. Suitable for filing with a served agency." />
          <CheckBox IsChecked="{Binding IncludeStations}"
                    Content="Stations heard CSV (AAR_…_Stations.csv)"
                    ToolTip.Tip="All heard stations with callsign, last heard time, position, speed, and comment. Opens in Excel or Numbers." />
          <CheckBox IsChecked="{Binding IncludeMessages}"
                    Content="Messages CSV (AAR_…_Messages.csv)"
                    ToolTip.Tip="All sent and received messages with timestamps, direction, and delivery status." />
          <CheckBox IsChecked="{Binding IncludePacketLog}"
                    Content="Raw packet log CSV (AAR_…_PacketLog.csv)"
                    ToolTip.Tip="Complete raw APRS packet log. Large file — only needed for detailed technical analysis." />
          <CheckBox IsChecked="{Binding IncludeIcs214}"
                    Content="ICS-214 Activity Log (ICS214_….txt)"
                    ToolTip.Tip="FEMA ICS-214 standard activity log form. Required by many served agencies for documentation of communications activities." />
        </StackPanel>

        <!-- ICS-214 operator fields — shown when ICS-214 is selected -->
        <Border IsVisible="{Binding IncludeIcs214}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1" CornerRadius="5" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="ICS-214 Operator Information" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
              <StackPanel Spacing="2">
                <TextBlock Text="Operator name" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding OperatorName}" Watermark="e.g. James Smith" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="ICS position" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding IcsPosition}" Watermark="e.g. Communications Unit Leader" />
              </StackPanel>
              <StackPanel Grid.Row="1" Spacing="2">
                <TextBlock Text="Home agency / club" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
                <TextBox Text="{Binding HomeAgency}" Watermark="e.g. Atlanta ARES" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Border Background="{DynamicResource WarnBgBrush}" BorderBrush="{DynamicResource WarnBorderBrush}"
                BorderThickness="1" CornerRadius="5" Padding="10">
          <TextBlock FontSize="10" Foreground="{DynamicResource WarnTextBrush}" TextWrapping="Wrap"
                     Text="Files will be saved to your Downloads folder. Each file is named with the date and time of export so multiple reports don't overwrite each other." />
        </Border>

        <TextBlock Text="{Binding StatusText}" FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </ScrollViewer>

    <!-- Buttons -->
    <Border Grid.Row="2" Padding="16,12" Background="{DynamicResource AppBgAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBlock Grid.Column="0" Text="Files save to ~/Downloads" FontSize="10"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Command="{Binding ExportCommand}"
                Content="Export" Padding="20,8"
                IsEnabled="{Binding IsNotExporting}" />
        <Button Grid.Column="2" x:Name="CloseButton"
                Content="Close" Padding="14,8" />
      </Grid>
    </Border>
  </Grid>
</Window>

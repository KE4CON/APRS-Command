<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             x:Class="Aprs.Desktop.Views.AudioConfigView"
             x:DataType="vm:AudioConfigViewModel">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="14" Margin="0,4">

      <!-- Header -->
      <StackPanel Spacing="2">
        <TextBlock Text="Audio Alerts" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Foreground="{DynamicResource TextSubtleBrush}" FontSize="12" TextWrapping="Wrap"
                   Text="APRS Command plays a distinct sound for each type of alert. Sounds are generated internally — no external audio files are required. If audio is unavailable the app continues normally and logs the failure." />
      </StackPanel>

      <!-- Volume -->
      <Border Grid.Row="1" BorderBrush="{DynamicResource TextSidebarBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Background="{DynamicResource TextTitleBarBrush}">
        <StackPanel Spacing="10">
          <TextBlock Text="Volume" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Slider Minimum="0" Maximum="100"
                    Value="{Binding VolumePercent}"
                    TickFrequency="10"
                    IsSnapToTickEnabled="False" />
            <TextBlock Grid.Column="1"
                       Text="{Binding VolumePercent, StringFormat='{}{0}%'}"
                       Width="40"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Sound toggles -->
      <Border Grid.Row="2" BorderBrush="{DynamicResource TextSidebarBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Background="{DynamicResource TextTitleBarBrush}">
        <StackPanel Spacing="12">
          <TextBlock Text="Play sounds for" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
            <CheckBox Grid.Row="0" IsChecked="{Binding PlayOnMessageReceived}" />
            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="1">
              <TextBlock Text="Incoming message" FontWeight="SemiBold" Foreground="{DynamicResource AppBgAltBrush}" />
              <TextBlock Text="Two ascending tones — plays when a direct message arrives addressed to your callsign." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <CheckBox Grid.Row="1" IsChecked="{Binding PlayOnWarningAlert}" />
            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="1">
              <TextBlock Text="Warning alert" FontWeight="SemiBold" Foreground="{DynamicResource AppBgAltBrush}" />
              <TextBlock Text="Three medium pulses — plays when a Warning-severity alert rule triggers." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <CheckBox Grid.Row="2" IsChecked="{Binding PlayOnCriticalAlert}" />
            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="1">
              <TextBlock Text="Critical alert" FontWeight="SemiBold" Foreground="{DynamicResource AppBgAltBrush}" />
              <TextBlock Text="Rapid urgent pulses — plays when a Critical-severity alert rule triggers." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <CheckBox Grid.Row="3" IsChecked="{Binding PlayOnConnectionEvents}" />
            <StackPanel Grid.Row="3" Grid.Column="1" Spacing="1">
              <TextBlock Text="Connection events" FontWeight="SemiBold" Foreground="{DynamicResource AppBgAltBrush}" />
              <TextBlock Text="Single rising or falling tone — plays when APRS-IS connects or disconnects." FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Custom sound files -->
      <Border Grid.Row="3" BorderBrush="{DynamicResource TextSidebarBrush}" BorderThickness="1"
              CornerRadius="6" Padding="14" Background="{DynamicResource TextTitleBarBrush}">
        <StackPanel Spacing="10">
          <StackPanel Spacing="2">
            <TextBlock Text="Custom Sound Files" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                       Text="Optionally supply your own WAV files for each alert type. Leave blank to use the built-in synthesised tones." />
          </StackPanel>

          <!-- Message received -->
          <Grid ColumnDefinitions="120,*,Auto" ColumnSpacing="8">
            <TextBlock Text="Message received" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding CustomSoundMessageReceived}"
                     Watermark="Path to .wav file (leave blank for built-in tone)" FontSize="10" />
            <Button Grid.Column="2" Content="Browse…" Padding="8,4"
                    Command="{Binding BrowseMessageSoundCommand}" />
          </Grid>

          <!-- Warning alert -->
          <Grid ColumnDefinitions="120,*,Auto" ColumnSpacing="8">
            <TextBlock Text="Warning alert" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding CustomSoundWarningAlert}"
                     Watermark="Path to .wav file (leave blank for built-in tone)" FontSize="10" />
            <Button Grid.Column="2" Content="Browse…" Padding="8,4"
                    Command="{Binding BrowseWarningSoundCommand}" />
          </Grid>

          <!-- Critical alert -->
          <Grid ColumnDefinitions="120,*,Auto" ColumnSpacing="8">
            <TextBlock Text="Critical alert" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding CustomSoundCriticalAlert}"
                     Watermark="Path to .wav file (leave blank for built-in tone)" FontSize="10" />
            <Button Grid.Column="2" Content="Browse…" Padding="8,4"
                    Command="{Binding BrowseCriticalSoundCommand}" />
          </Grid>

          <!-- Connected -->
          <Grid ColumnDefinitions="120,*,Auto" ColumnSpacing="8">
            <TextBlock Text="APRS-IS connected" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding CustomSoundConnected}"
                     Watermark="Path to .wav file (leave blank for built-in tone)" FontSize="10" />
            <Button Grid.Column="2" Content="Browse…" Padding="8,4"
                    Command="{Binding BrowseConnectedSoundCommand}" />
          </Grid>

          <!-- Disconnected -->
          <Grid ColumnDefinitions="120,*,Auto" ColumnSpacing="8">
            <TextBlock Text="APRS-IS disconnected" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding CustomSoundDisconnected}"
                     Watermark="Path to .wav file (leave blank for built-in tone)" FontSize="10" />
            <Button Grid.Column="2" Content="Browse…" Padding="8,4"
                    Command="{Binding BrowseDisconnectedSoundCommand}" />
          </Grid>

          <Button Content="Test message sound" Command="{Binding TestSoundCommand}"
                  Padding="10,5" HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- Voice Readout -->
      <Border Grid.Row="4"
              BorderBrush="{DynamicResource AccentBlueBorderBrush}"
              BorderThickness="1" CornerRadius="6" Padding="14"
              Background="{DynamicResource AccentBlueBgBrush}">
        <StackPanel Spacing="10">
          <StackPanel Spacing="2">
            <TextBlock Text="Voice Readout" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Text="Reads alerts aloud using your operating system's built-in text-to-speech. No internet or API key required. macOS uses 'say', Windows uses System.Speech, Linux uses espeak-ng." />
          </StackPanel>

          <CheckBox IsChecked="{Binding VoiceEnabled}"
                    ToolTip.Tip="Master switch for all voice readout. Must be checked for any speech to occur.">
            <TextBlock Text="Enable voice readout  (master switch)" FontWeight="SemiBold" />
          </CheckBox>

          <!-- Voice picker -->
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,4,0,0">
            <TextBlock Text="Voice:" VerticalAlignment="Center" FontSize="12"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AvailableVoices}"
                      SelectedItem="{Binding SelectedVoice}"
                      HorizontalAlignment="Stretch"
                      ToolTip.Tip="Choose which voice to use for readout. 'System Default' uses whatever voice is set as the default in your operating system settings. On macOS you can add more voices in System Settings > Accessibility > Spoken Content. On Windows, install additional voices in Settings > Time and Language > Speech." />
            <Button Grid.Column="2" Content="Test Voice"
                    Padding="10,5" FontSize="11"
                    Click="OnTestVoiceClick"
                    ToolTip.Tip="Plays a short test phrase using the selected voice. Voice readout does not need to be enabled to test." />
          </Grid>

          <StackPanel Spacing="6" Margin="24,0,0,0">
            <CheckBox IsChecked="{Binding VoiceSpeakMessages}"
                      ToolTip.Tip="Reads the sender's callsign and message body when a direct APRS message arrives. Example: 'Message from W9ABC. Are you on frequency?'">
              <StackPanel Spacing="1">
                <TextBlock Text="Incoming messages" FontSize="12" />
                <TextBlock Text="Reads callsign and body when a direct message arrives." FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </CheckBox>
            <CheckBox IsChecked="{Binding VoiceSpeakNetCheckIns}"
                      ToolTip.Tip="Announces station callsigns as they check in to the net via the Net Control window.">
              <StackPanel Spacing="1">
                <TextBlock Text="Net check-ins" FontSize="12" />
                <TextBlock Text="Announces callsigns as stations check in to the net." FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </CheckBox>
            <CheckBox IsChecked="{Binding VoiceSpeakWeatherAlerts}"
                      ToolTip.Tip="Reads National Weather Service alerts aloud when they arrive. Useful during Skywarn activations.">
              <StackPanel Spacing="1">
                <TextBlock Text="NWS weather alerts" FontSize="12" />
                <TextBlock Text="Reads severe weather alerts from the National Weather Service." FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </CheckBox>
            <CheckBox IsChecked="{Binding VoiceSpeakStationAlerts}"
                      ToolTip.Tip="Announces tracked station movements and geofence triggers. Can be noisy in busy areas.">
              <StackPanel Spacing="1">
                <TextBlock Text="Station alerts" FontSize="12" />
                <TextBlock Text="Announces tracked station movements and geofence triggers." FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </CheckBox>
            <CheckBox IsChecked="{Binding VoiceSpeakConnectionEvents}"
                      ToolTip.Tip="Announces APRS-IS connect and disconnect events. Useful when the app is running in the background.">
              <StackPanel Spacing="1">
                <TextBlock Text="Connection events" FontSize="12" />
                <TextBlock Text="Announces APRS-IS connect and disconnect events." FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </CheckBox>
            <CheckBox IsChecked="{Binding VoiceSpeakBeaconConfirmations}"
                      ToolTip.Tip="Announces each successful beacon transmission. Most operators leave this off.">
              <StackPanel Spacing="1">
                <TextBlock Text="Beacon confirmations" FontSize="12" />
                <TextBlock Text="Announces each successful beacon transmission." FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </CheckBox>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Save / Revert -->
      <Grid Grid.Row="5" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
        <Button Command="{Binding SaveCommand}" Content="Save" Padding="14,6" />
        <Button Grid.Column="1" Command="{Binding RevertCommand}" Content="Revert" Padding="10,6" />
        <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.OfflineMapDownloadWindow"
        x:DataType="vm:OfflineMapDownloadViewModel"
        Title="Offline Map Download"
        Width="520" Height="560"
        MinWidth="460" MinHeight="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource AppBgBrush}">

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}" Padding="16,12">
      <StackPanel Spacing="2">
        <TextBlock Text="Offline Map Download" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextTitleBarBrush}" />
        <TextBlock FontSize="11" Foreground="{DynamicResource TextSidebarBrush}" TextWrapping="Wrap"
                   Text="Pre-download map tiles for use without an internet connection. Define a geographic area, estimate the download size, then download." />
      </StackPanel>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" Padding="18,14">
      <StackPanel Spacing="14">

        <!-- Area name -->
        <StackPanel Spacing="3">
          <TextBlock Text="Area name" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBox Text="{Binding AreaName}" Watermark="e.g. Fulton County GA, Field Day Site" />
        </StackPanel>

        <!-- Map provider -->
        <StackPanel Spacing="3">
          <TextBlock Text="Map layer" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <ComboBox ItemsSource="{Binding Providers}"
                    SelectedIndex="{Binding SelectedProviderIndex}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <!-- Bounding box -->
        <StackPanel Spacing="4">
          <TextBlock Text="Bounding box (decimal degrees)" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6">
            <StackPanel Spacing="2">
              <TextBlock Text="North latitude" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
              <NumericUpDown Value="{Binding NorthLat}" Minimum="-90" Maximum="90"
                             Increment="0.1" FormatString="F4" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="South latitude" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
              <NumericUpDown Value="{Binding SouthLat}" Minimum="-90" Maximum="90"
                             Increment="0.1" FormatString="F4" />
            </StackPanel>
            <StackPanel Grid.Row="1" Spacing="2">
              <TextBlock Text="West longitude" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
              <NumericUpDown Value="{Binding WestLon}" Minimum="-180" Maximum="180"
                             Increment="0.1" FormatString="F4" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
              <TextBlock Text="East longitude" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
              <NumericUpDown Value="{Binding EastLon}" Minimum="-180" Maximum="180"
                             Increment="0.1" FormatString="F4" />
            </StackPanel>
          </Grid>
        </StackPanel>

        <!-- Zoom range -->
        <StackPanel Spacing="4">
          <TextBlock Text="Zoom level range" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"
                     Text="Higher zoom levels download far more tiles. Zoom 8-12 is good for regional awareness. Zoom 14+ is for detailed street-level maps at specific locations." />
          <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
            <StackPanel Spacing="2">
              <TextBlock Text="Minimum zoom" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
              <NumericUpDown Value="{Binding MinZoom}" Minimum="1" Maximum="18"
                             Increment="1" FormatString="0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Maximum zoom" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" />
              <NumericUpDown Value="{Binding MaxZoom}" Minimum="1" Maximum="18"
                             Increment="1" FormatString="0" />
            </StackPanel>
          </Grid>
        </StackPanel>

        <!-- Estimate result -->
        <Border IsVisible="{Binding HasEstimate}"
                Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1" CornerRadius="5" Padding="12,8">
          <TextBlock Text="{Binding EstimateText}" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource AccentBlueMidBrush}" />
        </Border>

        <!-- Progress bar -->
        <StackPanel IsVisible="{Binding IsDownloading}" Spacing="4">
          <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="8" />
          <TextBlock Text="{Binding StatusText}" FontSize="10"
                     Foreground="{DynamicResource TextMutedBrush}" />
        </StackPanel>

        <!-- Status when not downloading -->
        <TextBlock IsVisible="{Binding IsNotDownloading}"
                   Text="{Binding StatusText}" FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap" />

      </StackPanel>
    </ScrollViewer>

    <!-- Buttons -->
    <Border Grid.Row="2" Padding="16,12" Background="{DynamicResource AppBgAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
        <Button Command="{Binding EstimateCommand}" Content="Estimate"
                IsEnabled="{Binding IsNotDownloading}" Padding="12,6" />
        <Button Grid.Column="1" Command="{Binding DownloadCommand}" Content="Download"
                IsEnabled="{Binding HasEstimate}" Padding="14,6" />
        <Button Grid.Column="2" Command="{Binding CancelCommand}" Content="Cancel Download"
                IsVisible="{Binding IsDownloading}" Padding="12,6" />
        <Button Grid.Column="3" x:Name="CloseButton" Content="Close" Padding="12,6" />
      </Grid>
    </Border>
  </Grid>
</Window>

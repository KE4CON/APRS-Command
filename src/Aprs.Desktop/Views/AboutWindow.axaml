<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Aprs.Desktop.Views.AboutWindow"
        Title="About APRS Command"
        Width="440"
        Height="380"
        MinWidth="440"
        MaxWidth="440"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="*,Auto" Background="{DynamicResource SurfaceBgBrush}">

    <!-- Main content -->
    <StackPanel Spacing="0" VerticalAlignment="Center" Margin="40,32">

      <!-- App name and version -->
      <TextBlock Text="APRS Command"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
      <TextBlock x:Name="VersionText"
                 FontSize="13"
                 Foreground="{DynamicResource TextMutedBrush}"
                 Margin="0,2,0,0" />

      <Border Height="1" Background="{DynamicResource TextOnDarkBrush}" Margin="0,20,0,20" />

      <!-- Description -->
      <TextBlock Text="A cross-platform APRS client for amateur radio operators."
                 FontSize="12"
                 Foreground="{DynamicResource TitleBarBorderBrush}"
                 TextWrapping="Wrap"
                 Margin="0,0,0,16" />

      <!-- Details grid -->
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
            ColumnSpacing="12" RowSpacing="6">
        <TextBlock Grid.Row="0" Text="Operator:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CallsignText" FontSize="11" Foreground="{DynamicResource AppBgAltBrush}" FontWeight="SemiBold" />

        <TextBlock Grid.Row="1" Text="Runtime:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RuntimeText" FontSize="11" Foreground="{DynamicResource AppBgAltBrush}" />

        <TextBlock Grid.Row="2" Text="Platform:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PlatformText" FontSize="11" Foreground="{DynamicResource AppBgAltBrush}" />

        <TextBlock Grid.Row="3" Text="Source:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
        <TextBlock Grid.Row="3" Grid.Column="1"
                   Text="github.com/KE4CON/APRS-Command"
                   FontSize="11"
                   Foreground="{DynamicResource AccentBlueMidBrush}"
                   Cursor="Hand"
                   PointerPressed="RepoLink_PointerPressed" />

        <TextBlock Grid.Row="4" Text="License:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
        <TextBlock Grid.Row="4" Grid.Column="1" Text="MIT" FontSize="11" Foreground="{DynamicResource AppBgAltBrush}" />
      </Grid>

      <Border Height="1" Background="{DynamicResource TextOnDarkBrush}" Margin="0,20,0,16" />

      <TextBlock FontSize="11"
                 Foreground="{DynamicResource TextSubtleBrush}"
                 TextWrapping="Wrap"
                 Margin="0,0,0,6"
                 Text="Built on Avalonia UI, Mapsui, and BruTile." />
      <TextBlock FontSize="11"
                 Foreground="{DynamicResource TextSubtleBrush}"
                 TextWrapping="Wrap"
                 Text="Inspired by the vision of Bob Bruninga WB4APR, father of APRS, who designed it as a situational awareness tool — and by UI-View32, written by Roger Barker G4IDE. Released under GPL v3 so it can live on." />
    </StackPanel>

    <!-- Close button -->
    <Border Grid.Row="1"
            Background="{DynamicResource TextTitleBarBrush}"
            BorderBrush="{DynamicResource TextOnDarkBrush}"
            BorderThickness="0,1,0,0"
            Padding="20,12">
      <Button Content="Close"
              HorizontalAlignment="Right"
              Padding="20,6"
              Click="Close_Click" />
    </Border>
  </Grid>
</Window>

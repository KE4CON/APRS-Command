<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Aprs.Desktop.Views.MainStatusBarView">
  <Border Background="{DynamicResource AppBorderStrongBrush}"
          BorderBrush="{DynamicResource TextSidebarBrush}"
          BorderThickness="0,1,0,0"
          Padding="12,7">
    <Grid ColumnDefinitions="*,Auto,Auto"
          ColumnSpacing="18">
      <TextBlock Text="Ready"
                 Foreground="{DynamicResource TitleBarBorderBrush}"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="1"
                 Text="APRS-IS Disconnected"
                 Foreground="{DynamicResource TextSubtleBrush}"
                 VerticalAlignment="Center" />
      <TextBlock Grid.Column="2"
                 Text="RF TX Disabled"
                 Foreground="{DynamicResource AccentTealBrush}"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
    </Grid>
  </Border>
</UserControl>

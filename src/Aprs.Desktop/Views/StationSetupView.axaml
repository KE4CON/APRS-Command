<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             xmlns:mapping="using:Aprs.Mapping"
             x:Class="Aprs.Desktop.Views.StationSetupView"
             x:DataType="vm:StationSetupViewModel">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
          RowSpacing="14"
          Margin="0,4">

      <!-- Header -->
      <StackPanel Spacing="2">
        <TextBlock Text="Station Setup"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#0F172A" />
        <TextBlock Text="Your APRS station identity and beacon settings. Save before transmitting."
                   Foreground="#526173"
                   FontSize="12"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Identity row -->
      <Grid Grid.Row="1"
            ColumnDefinitions="*,Auto,*,*"
            ColumnSpacing="8">
        <StackPanel Spacing="2">
          <TextBlock Text="Callsign" FontSize="11" Foreground="#64748B" />
          <TextBox Text="{Binding Callsign}"
                   Watermark="e.g. KE4CON" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="SSID" FontSize="11" Foreground="#64748B" />
          <NumericUpDown Value="{Binding Ssid}"
                         Minimum="0" Maximum="15"
                         Width="90" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="2">
          <TextBlock Text="Latitude" FontSize="11" Foreground="#64748B" />
          <TextBox Text="{Binding Latitude}"
                   Watermark="e.g. 39.0583" />
        </StackPanel>
        <StackPanel Grid.Column="3" Spacing="2">
          <TextBlock Text="Longitude" FontSize="11" Foreground="#64748B" />
          <TextBox Text="{Binding Longitude}"
                   Watermark="e.g. -84.5083" />
        </StackPanel>
      </Grid>

      <!-- Symbol picker -->
      <Border Grid.Row="2"
              BorderBrush="#CBD5E1"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12"
              Background="#F8FAFC">
        <StackPanel Spacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="Station symbol"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#0F172A" />
            <TextBlock Text="Click your station type. The symbol code is set automatically."
                       FontSize="11"
                       Foreground="#64748B" />
          </StackPanel>

          <!-- Symbol grid -->
          <ListBox ItemsSource="{Binding AvailableSymbols}"
                   SelectedItem="{Binding SelectedSymbol}"
                   Background="Transparent"
                   BorderThickness="0">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="mapping:AprsSymbol">
                <Border Width="80"
                        Margin="2"
                        Padding="6,8"
                        CornerRadius="4"
                        ToolTip.Tip="{Binding Description}">
                  <StackPanel Spacing="4"
                              HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FallbackDisplayText}"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="#1D4ED8" />
                    <TextBlock Text="{Binding Description}"
                               FontSize="9"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="#475569"
                               MaxWidth="76" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Selected symbol display -->
          <Border Background="#EFF6FF"
                  BorderBrush="#BFDBFE"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="10,7">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock Text="Selected: "
                         FontSize="12"
                         Foreground="#64748B"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding SymbolDisplay}"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#1D4ED8"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>
        </StackPanel>
      </Border>

      <!-- Beacon and comment -->
      <Grid Grid.Row="3"
            ColumnDefinitions="*,*,Auto,Auto"
            ColumnSpacing="8">
        <StackPanel Spacing="2">
          <TextBlock Text="Station comment" FontSize="11" Foreground="#64748B" />
          <TextBox Text="{Binding StationComment}"
                   Watermark="e.g. APRS Command" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="Beacon path" FontSize="11" Foreground="#64748B" />
          <TextBox Text="{Binding BeaconPath}"
                   Watermark="e.g. WIDE1-1,WIDE2-1" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="2">
          <TextBlock Text="APRS-IS interval (min)" FontSize="11" Foreground="#64748B" />
          <NumericUpDown Value="{Binding AprsIsBeaconMinutes}"
                         Minimum="1" Maximum="120"
                         Width="120" />
        </StackPanel>
        <StackPanel Grid.Column="3" Spacing="2">
          <TextBlock Text="RF interval (min)" FontSize="11" Foreground="#64748B" />
          <NumericUpDown Value="{Binding RfBeaconMinutes}"
                         Minimum="1" Maximum="120"
                         Width="120" />
        </StackPanel>
      </Grid>

      <!-- Transmit safety -->
      <Border Grid.Row="4"
              Background="#FEF3C7"
              BorderBrush="#F59E0B"
              BorderThickness="1"
              CornerRadius="5"
              Padding="12">
        <StackPanel Spacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="Transmit safety"
                       FontWeight="SemiBold"
                       Foreground="#92400E" />
            <TextBlock Text="All transmit is off by default. Enable master transmit first, then enable the specific destinations you want to beacon on."
                       Foreground="#92400E"
                       TextWrapping="Wrap"
                       FontSize="12" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="24">
            <CheckBox Content="Master transmit enabled"
                      IsChecked="{Binding TransmitEnabled}" />
            <CheckBox Content="APRS-IS transmit"
                      IsChecked="{Binding AprsIsTransmitEnabled}" />
            <CheckBox Content="RF transmit"
                      IsChecked="{Binding RfTransmitEnabled}" />
            <CheckBox Content="Fixed station"
                      IsChecked="{Binding FixedStationMode}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Save / Revert -->
      <Grid Grid.Row="5"
            ColumnDefinitions="Auto,Auto,*"
            ColumnSpacing="8">
        <Button Command="{Binding SaveCommand}"
                Content="Save"
                Padding="14,6" />
        <Button Grid.Column="1"
                Command="{Binding RevertCommand}"
                Content="Revert"
                Padding="10,6" />
        <TextBlock Grid.Column="2"
                   Text="{Binding StatusText}"
                   Foreground="#475569"
                   VerticalAlignment="Center" />
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>

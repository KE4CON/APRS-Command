<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Aprs.Desktop.ViewModels"
             xmlns:mapping="using:Aprs.Mapping"
             x:Class="Aprs.Desktop.Views.StationSetupView"
             x:DataType="vm:StationSetupViewModel">
  <ScrollViewer>
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
          RowSpacing="14"
          Margin="0,4">

      <!-- Header -->
      <StackPanel Spacing="2">
        <TextBlock Text="Station Setup"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Text="Your APRS station identity and beacon settings. Save before transmitting."
                   Foreground="{DynamicResource TextSubtleBrush}"
                   FontSize="12"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Identity row -->
      <Grid Grid.Row="1"
            ColumnDefinitions="*,Auto,*,*"
            ColumnSpacing="8">
        <StackPanel Spacing="2">
          <TextBlock Text="Callsign" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <TextBox Text="{Binding Callsign}"
                   Watermark="e.g. KE4CON" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="SSID" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <NumericUpDown Value="{Binding Ssid}"
                         Minimum="0" Maximum="15"
                         Width="90"
                         ToolTip.Tip="Secondary Station ID (0-15). Use 0 for your primary home station. Use 1-9 for mobile, portable, or secondary stations. KE4CON with SSID 1 appears as KE4CON-1 on the network." />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="2">
          <TextBlock Text="Latitude" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <TextBox Text="{Binding Latitude}"
                   Watermark="e.g. 39.0583" />
        </StackPanel>
        <StackPanel Grid.Column="3" Spacing="2">
          <TextBlock Text="Longitude" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <TextBox Text="{Binding Longitude}"
                   Watermark="e.g. -84.5083" />
        </StackPanel>
      </Grid>

      <!-- Distance unit preference + filter radius (required) -->
      <Border Grid.Row="2"
              BorderBrush="{DynamicResource AccentBlueBorderBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12,10"
              Background="{DynamicResource AccentBlueBgBrush}">
        <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="16">
          <StackPanel Spacing="4">
            <TextBlock Text="Distance units  (required)"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Text="Choose the unit system you prefer for all distances in the app. The app converts to kilometres behind the scenes wherever APRS-IS requires it." />
            <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,4,0,0">
              <RadioButton Content="Miles  (US / UK)"
                           IsChecked="{Binding UseMetric, Converter={x:Static BoolConverters.Not}}"
                           FontSize="13" />
              <RadioButton Content="Kilometres  (metric)"
                           IsChecked="{Binding UseMetric}"
                           FontSize="13" />
            </StackPanel>
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
            <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}">
              <Run Text="APRS-IS receive filter radius (" /><Run Text="{Binding FilterUnitLabel}" /><Run Text=")" />
            </TextBlock>
            <NumericUpDown Value="{Binding FilterRadiusDisplay}"
                           Minimum="10" Maximum="5000"
                           Width="160" />
            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       Text="How far from your station to receive APRS traffic." />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Symbol picker -->
      <Border Grid.Row="3"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12"
              Background="{DynamicResource TextTitleBarBrush}">
        <StackPanel Spacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="Station symbol"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Click your station type. The symbol code is set automatically."
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>

          <!-- Symbol grid -->
          <ListBox ItemsSource="{Binding AvailableSymbols}"
                   SelectedItem="{Binding SelectedSymbol}"
                   Background="Transparent"
                   BorderThickness="0">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="mapping:AprsSymbol">
                <Border Width="80"
                        Margin="2"
                        Padding="6,8"
                        CornerRadius="4"
                        ToolTip.Tip="{Binding Description}">
                  <StackPanel Spacing="4"
                              HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FallbackDisplayText}"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AccentBlueBrush}" />
                    <TextBlock Text="{Binding Description}"
                               FontSize="9"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               MaxWidth="76" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Selected symbol display -->
          <Border Background="{DynamicResource AccentBlueBgBrush}"
                  BorderBrush="{DynamicResource AccentBlueBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="10,7">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock Text="Selected: "
                         FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding SymbolDisplay}"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>
        </StackPanel>
      </Border>

      <!-- Beacon and comment -->
      <Grid Grid.Row="4"
            ColumnDefinitions="*,*,Auto,Auto"
            ColumnSpacing="8">
        <StackPanel Spacing="2">
          <TextBlock Text="Station comment" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <TextBox Text="{Binding StationComment}"
                   Watermark="e.g. APRS Command" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="Beacon path" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <TextBox Text="{Binding BeaconPath}"
                   Watermark="e.g. WIDE1-1,WIDE2-1"
                   ToolTip.Tip="Controls how your packet is relayed by digipeaters. WIDE1-1,WIDE2-1 is correct for most US stations. IMPORTANT: no spaces — WIDE 1-1 is wrong and will be silently rejected by APRS-IS. Spaces are automatically removed when you save." />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="2">
          <TextBlock Text="APRS-IS interval (min)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <NumericUpDown Value="{Binding AprsIsBeaconMinutes}"
                         Minimum="1" Maximum="120"
                         Width="120"
                         ToolTip.Tip="How often your position is automatically sent to APRS-IS, in minutes. Minimum is 5 minutes. 10-15 minutes is typical for a fixed home station. The Beacon Now button transmits immediately regardless of this interval." />
        </StackPanel>
        <StackPanel Grid.Column="3" Spacing="2">
          <TextBlock Text="RF interval (min)" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
          <NumericUpDown Value="{Binding RfBeaconMinutes}"
                         Minimum="1" Maximum="120"
                         Width="120"
                         ToolTip.Tip="How often your position is automatically sent over the radio (RF), in minutes. Only applies when RF transmit is enabled and a radio/TNC is connected. RF beaconing is independent of APRS-IS beaconing." />
        </StackPanel>
      </Grid>

      <!-- Ring distances -->
      <Grid Grid.Row="5"
            ColumnDefinitions="Auto,*,Auto,*,Auto,*"
            ColumnSpacing="8">
        <TextBlock Text="Range rings:" VerticalAlignment="Center"
                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
        <NumericUpDown Grid.Column="1" Value="{Binding Ring1Distance}"
                       Minimum="1" Maximum="9999"
                       ToolTip.Tip="Inner ring distance (blue). Enter in your preferred unit (miles or km)." />
        <TextBlock Grid.Column="2" Text="/" VerticalAlignment="Center"
                   FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                   Margin="4,0" />
        <NumericUpDown Grid.Column="3" Value="{Binding Ring2Distance}"
                       Minimum="1" Maximum="9999"
                       ToolTip.Tip="Middle ring distance (green). Enter in your preferred unit (miles or km)." />
        <TextBlock Grid.Column="4" Text="/" VerticalAlignment="Center"
                   FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                   Margin="4,0" />
        <NumericUpDown Grid.Column="5" Value="{Binding Ring3Distance}"
                       Minimum="1" Maximum="9999"
                       ToolTip.Tip="Outer ring distance (red). Enter in your preferred unit (miles or km)." />
      </Grid>

      <!-- PHG encoder (Power, Height, Gain, Directivity) -->
      <Border Grid.Row="6"
              BorderBrush="{DynamicResource TextSidebarBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12,10"
              Background="{DynamicResource TextTitleBarBrush}">
        <StackPanel Spacing="8">
          <TextBlock Text="PHG Data (Power / Height / Gain / Directivity)"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap"
                     Text="PHG describes your station's RF coverage in beacons. Set all four values to enable. Leave as None to omit PHG from your beacon." />
          <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
            <StackPanel Spacing="2">
              <TextBlock Text="Power" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox x:Name="PhgPowerCombo"
                        ItemsSource="{Binding PhgPowerOptions}"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="PhgDropdown_Changed"
                        ToolTip.Tip="Your station's transmit power in watts. Used to estimate RF coverage radius. Select None to omit PHG from your beacon." />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2">
              <TextBlock Text="Height HAAT" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox x:Name="PhgHeightCombo"
                        ItemsSource="{Binding PhgHeightOptions}"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="PhgDropdown_Changed"
                        ToolTip.Tip="Height Above Average Terrain (HAAT) of your antenna in feet. This is the height of your antenna above the surrounding terrain, not above ground level. Has the biggest impact on coverage range." />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="2">
              <TextBlock Text="Antenna gain" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox x:Name="PhgGainCombo"
                        ItemsSource="{Binding PhgGainOptions}"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="PhgDropdown_Changed"
                        ToolTip.Tip="Your antenna's gain in dBd (decibels relative to a dipole). A simple vertical antenna is typically 0-3 dBd. A beam or high-gain vertical may be 6-9 dBd." />
            </StackPanel>
            <StackPanel Grid.Column="3" Spacing="2">
              <TextBlock Text="Directivity" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
              <ComboBox x:Name="PhgDirectivityCombo"
                        ItemsSource="{Binding PhgDirectivityOptions}"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="PhgDropdown_Changed"
                        ToolTip.Tip="The direction your antenna focuses its energy. Omni = equal coverage in all directions. Directional antennas point toward a specific compass heading." />
            </StackPanel>
          </Grid>
          <TextBlock x:Name="PhgResultText"
                     FontSize="11"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>
      </Border>

      <!-- Transmit safety -->
      <Border Grid.Row="7"
              Background="{DynamicResource WarnBgBrush}"
              BorderBrush="{DynamicResource WarnBorderBrush}"
              BorderThickness="1"
              CornerRadius="5"
              Padding="12">
        <StackPanel Spacing="8">
          <StackPanel Spacing="2">
            <TextBlock Text="Transmit safety"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource WarnTextStrongBrush}" />
            <TextBlock Text="All transmit is off by default. Enable master transmit first, then enable the specific destinations you want to beacon on."
                       Foreground="{DynamicResource WarnTextStrongBrush}"
                       TextWrapping="Wrap"
                       FontSize="12" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="24">
            <CheckBox Content="Master transmit enabled"
                      IsChecked="{Binding TransmitEnabled}"
                      ToolTip.Tip="Master on/off switch for all transmission. Must be checked before any beacon or message can be sent. Turn this off to operate in receive-only mode." />
            <CheckBox Content="APRS-IS transmit"
                      IsChecked="{Binding AprsIsTransmitEnabled}"
                      ToolTip.Tip="Allows sending beacons and messages to the APRS-IS internet network. Requires a valid passcode in Settings > Connections. Master transmit must also be enabled." />
            <CheckBox Content="RF transmit"
                      IsChecked="{Binding RfTransmitEnabled}"
                      ToolTip.Tip="Allows sending beacons over the radio. Requires a connected TNC or sound card interface. Master transmit must also be enabled." />
            <CheckBox Content="Fixed station"
                      IsChecked="{Binding FixedStationMode}"
                      ToolTip.Tip="Check this if your station does not move. Uses the latitude and longitude you entered above rather than a GPS source. Most home stations should have this checked." />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Save / Revert -->
      <Grid Grid.Row="8"
            ColumnDefinitions="Auto,Auto,*"
            ColumnSpacing="8">
        <Button Command="{Binding SaveCommand}"
                Content="Save"
                Padding="14,6" />
        <Button Grid.Column="1"
                Command="{Binding RevertCommand}"
                Content="Revert"
                Padding="10,6" />
        <TextBlock Grid.Column="2"
                   Text="{Binding StatusText}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center" />
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>

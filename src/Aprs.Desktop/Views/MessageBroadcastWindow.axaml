<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Aprs.Desktop.ViewModels"
        x:Class="Aprs.Desktop.Views.MessageBroadcastWindow"
        x:DataType="vm:MessageBroadcastViewModel"
        Title="Message Broadcast"
        Width="580" Height="500"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource AppBgBrush}">

    <!-- Compose -->
    <Border Grid.Row="0" Background="{DynamicResource TitleBarBgBrush}" Padding="16,12">
      <StackPanel Spacing="10">
        <StackPanel Spacing="2">
          <TextBlock Text="Message Broadcast" FontSize="16" FontWeight="Bold"
                     Foreground="{DynamicResource TextTitleBarBrush}" />
          <TextBlock FontSize="10" Foreground="{DynamicResource TextSidebarBrush}"
                     Text="Send one message to multiple stations. Separate callsigns with commas." />
        </StackPanel>

        <StackPanel Spacing="2">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock Text="Recipients (comma-separated)" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
            <Button Grid.Column="1" Command="{Binding AddFromRosterCommand}"
                    Content="＋ From net roster" Padding="8,3" FontSize="10" />
          </Grid>
          <TextBox Text="{Binding RecipientList}"
                   Watermark="e.g. W4ABC, KD4XYZ, N4DEF"
                   AcceptsReturn="False" />
          <TextBlock FontSize="9" Foreground="{DynamicResource TextMutedBrush}">
            <Run Text="{Binding RecipientCount}" /><Run Text=" recipient(s)" />
          </TextBlock>
        </StackPanel>

        <StackPanel Spacing="2">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Message" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" FontSize="9"
                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center">
              <Run Text="{Binding CharCount}" /><Run Text="/67 chars" />
            </TextBlock>
          </Grid>
          <TextBox Text="{Binding MessageBody}"
                   Watermark="Message text (max 67 characters)"
                   MaxLength="67" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Results -->
    <Grid Grid.Row="1" RowDefinitions="Auto,*">
      <Border Grid.Row="0" Padding="14,6">
        <TextBlock Text="Results" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Results}"
               Background="{DynamicResource AppBgBrush}">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:BroadcastResultViewModel">
            <Grid ColumnDefinitions="30,120,*" Margin="4,2">
              <TextBlock Text="{Binding Icon}" FontSize="14" FontWeight="Bold"
                         Foreground="{Binding Color}" VerticalAlignment="Center"
                         HorizontalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding Callsign}" FontSize="12"
                         FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding Detail}" FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>

    <!-- Footer -->
    <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource AppBgAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
        <TextBlock Text="{Binding StatusText}" FontSize="10"
                   Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Command="{Binding SendCommand}"
                Content="📡 Send to all" Padding="12,5"
                IsEnabled="{Binding IsNotSending}" />
        <Button Grid.Column="2" Command="{Binding ClearCommand}"
                Content="Clear results" Padding="8,5" FontSize="10" />
        <Button Grid.Column="3" x:Name="CloseButton" Content="Close" Padding="12,5" />
      </Grid>
    </Border>
  </Grid>
</Window>
